    {
      "concept_id": "concept.kr.inheritance.legal_heir",
      "version": "1.0.0",
      "slug": "legal-heir",
      "preferred_term_ko": "상속인",
      "aliases_ko": [
        "법정상속인",
        "공동상속인"
      ],
      "plain_definition_ko": "사람이 사망했을 때 법이 정한 순위와 지위에 따라 그 사람의 재산상 권리와 의무를 이어받는 사람입니다.",
      "legal_definition_ko": "민법 제1000조 또는 제1003조에 따라 상속순위에 들고, 제1005조에 따라 상속개시 때 피상속인의 재산에 관한 포괄적 권리와 의무를 승계하는 사람입니다.",
      "elements_ko": [
        "피상속인의 사망으로 상속이 개시되어야 합니다.",
        "민법이 정한 친족 순위 또는 배우자 지위에 해당해야 합니다.",
        "선순위 상속인의 존재와 같은 순위 공동상속인의 범위를 함께 확인해야 합니다."
      ],
      "legal_effects_ko": [
        "피상속인의 재산에 관한 포괄적 권리와 의무를 승계합니다.",
        "여러 명이면 공동상속 관계가 생길 수 있습니다."
      ],
      "judgment_factors_ko": [
        "피상속인과의 친족관계",
        "배우자 여부",
        "선순위·동순위 상속인의 존재"
      ],
      "limits_and_counterexamples_ko": [
        "피상속인의 일신에 전속한 권리는 승계하지 않습니다.",
        "가족이라고 해서 모두 같은 순위의 상속인이 되는 것은 아닙니다."
      ],
      "confused_with_ko": [
        "상속을 포기한 사람",
        "유언으로 재산을 받는 수증자"
      ],
      "examples_ko": [
        "자녀와 배우자가 함께 있으면 두 사람 모두 상속인이 될 수 있고, 구체적인 순위와 지분은 별도로 확인합니다."
      ],
      "assertions": [
        {
