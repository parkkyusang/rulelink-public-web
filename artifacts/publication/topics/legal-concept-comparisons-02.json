  "content_entries": [
    {"content_id":"content.contract-rescission-vs-cancellation","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"contract-rescission-vs-cancellation","title_ko":"계약 해제와 취소, 무엇이 다른가요?","one_line_answer_ko":"해제는 성립한 계약의 불이행 등을, 취소는 계약 체결 당시 의사표시의 흠을 문제 삼습니다.","audience_situation_ko":"계약을 없애고 싶지만 해제와 취소 중 어떤 근거를 써야 할지 모르는 경우","key_points_ko":["원인이 계약 체결 전후 어느 시점에 있는지 구분합니다.","해제는 최고와 불이행, 취소는 착오·사기·강박 요건을 따집니다.","원상회복과 제3자 보호 규정도 서로 다릅니다."],"action_steps_ko":["계약서와 체결 경위를 확보합니다.","불이행 통지 또는 기망·강박 자료를 시간순으로 정리합니다.","선택한 법적 근거의 통지 요건을 확인합니다."],"facts_to_check_ko":["채무불이행의 내용","착오·기망·강박 발생 시점","제3자 권리 취득 여부"],"caution_ko":"단지 마음이 바뀌었다는 사정만으로 해제나 취소가 자동 인정되지는 않습니다.","search_intents_ko":["계약 해제 취소 차이","사기 계약 취소","채무불이행 계약 해제"],"body_sections":[{"heading_ko":"구분 기준","paragraphs_ko":["해제는 유효하게 성립한 계약을 채무불이행 등의 이유로 해소하는 제도입니다. 취소는 착오·사기·강박처럼 의사표시에 흠이 있었는지를 봅니다."]},{"heading_ko":"먼저 볼 자료","paragraphs_ko":["계약서, 이행기, 최고 내용, 광고·대화·송금 자료를 시간순으로 맞추면 어느 제도의 요건을 검토해야 하는지 분명해집니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-01"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-01"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0109","coord.legal-concept-comparisons-02.civil-act-ko-0110","coord.legal-concept-comparisons-02.civil-act-ko-0544","coord.legal-concept-comparisons-02.civil-act-ko-0548"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.reservation-deposit-vs-earnest-money"]},
    {"content_id":"content.reservation-deposit-vs-earnest-money","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"reservation-deposit-vs-earnest-money","title_ko":"가계약금과 계약금, 이름보다 무엇을 봐야 하나요?","one_line_answer_ko":"가계약금이라는 이름만으로 결론 내리지 말고 계약이 성립했는지와 지급금이 해약금으로 약정됐는지를 봐야 합니다.","audience_situation_ko":"부동산 거래 전에 일부 금액을 보냈다가 돌려받거나 계약을 끝내려는 경우","key_points_ko":["가계약금은 민법이 정한 독립 계약유형이 아닙니다.","목적물과 대금 등 본질적 사항의 합의 여부가 중요합니다.","해약금 해제는 이행 착수 전인지도 확인합니다."],"action_steps_ko":["송금 전후 문자와 통화 내용을 보존합니다.","목적물·대금·잔금일 합의 여부를 적습니다.","상대방의 이행 착수 여부를 확인합니다."],"facts_to_check_ko":["지급금 명칭과 반환 약정","본질적 사항 합의","이행 착수 시점"],"caution_ko":"지급액을 언제나 포기하거나 두 배로 돌려주면 계약이 끝난다고 단정할 수 없습니다.","search_intents_ko":["가계약금 반환","가계약금 계약금 차이","계약금 배액상환"],"body_sections":[{"heading_ko":"이름보다 약정 내용","paragraphs_ko":["매매계약은 목적물과 대금에 관한 의사 합치로 성립할 수 있습니다. 지급금의 이름보다 계약 성립과 돈의 기능을 확인해야 합니다."]},{"heading_ko":"해약금 해제 시점","paragraphs_ko":["별도 약정이 없다면 당사자 한쪽이 이행에 착수하기 전까지 계약금 포기 또는 배액상환 방식이 문제 됩니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-02"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-02"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0563","coord.legal-concept-comparisons-02.civil-act-ko-0565"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.contract-rescission-vs-cancellation"]},
    {"content_id":"content.certified-demand-vs-judicial-claim","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"certified-demand-vs-judicial-claim","title_ko":"내용증명을 보내면 시효가 멈추나요?","one_line_answer_ko":"내용증명 최고만으로 끝나는 것이 아니라 6개월 안에 재판상 청구 등 법정 후속조치를 해야 그 효과를 보전할 수 있습니다.","audience_situation_ko":"돈을 받으라는 내용증명을 보냈고 소송을 언제까지 해야 하는지 궁금한 경우","key_points_ko":["내용증명은 발송 내용과 시점을 입증하는 수단입니다.","최고 뒤 6개월이라는 후속조치 기한이 핵심입니다.","재판상 청구도 각하·기각·취하되면 효과가 달라질 수 있습니다."],"action_steps_ko":["최고 도달일을 확인합니다.","6개월 만료일을 계산합니다.","소송·지급명령 등 적합한 후속조치를 준비합니다."],"facts_to_check_ko":["채권의 원래 시효","내용증명 도달일","후속조치 접수와 종결 경위"],"caution_ko":"내용증명을 보냈다는 이유만으로 시효가 영구히 새로 시작한다고 생각하면 위험합니다.","search_intents_ko":["내용증명 시효","최고 6개월","재판상 청구 시효"],"body_sections":[{"heading_ko":"최고의 한계","paragraphs_ko":["최고는 권리행사를 알리는 조치지만, 민법은 6개월 안에 재판상 청구 등 후속조치를 요구합니다."]},{"heading_ko":"재판상 청구의 별도 효과","paragraphs_ko":["소송을 제기했더라도 각하·기각·취하 여부와 6개월 안의 재청구 등을 함께 확인해야 합니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-03"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-03"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0170","coord.legal-concept-comparisons-02.civil-act-ko-0174"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.contractual-interest-vs-default-damages"]},
    {"content_id":"content.lease-registration-application-vs-completion","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"lease-registration-application-vs-completion","title_ko":"임차권등기명령, 신청하면 바로 이사해도 되나요?","one_line_answer_ko":"신청만으로는 부족하고 등기부에 임차권등기가 완료됐는지 확인한 뒤 이사 시점을 정해야 합니다.","audience_situation_ko":"보증금을 못 받은 채 이사해야 해서 임차권등기명령을 신청한 경우","key_points_ko":["신청과 등기 완료는 다른 시점입니다.","보호 유지 효과는 등기 완료를 기준으로 봅니다.","전출·열쇠 반환 전에 등기부를 확인해야 합니다."],"action_steps_ko":["임대차 종료와 미반환 자료를 준비합니다.","관할 법원에 임차권등기명령을 신청합니다.","등기부상 완료를 확인한 뒤 전출 시점을 정합니다."],"facts_to_check_ko":["임대차 종료일","보증금 미반환액","등기 완료일과 전출일"],"caution_ko":"법원에 서류를 냈다는 사실과 등기부에 등기가 완료된 사실을 혼동하지 마세요.","search_intents_ko":["임차권등기 신청 후 이사","임차권등기 완료 확인","보증금 전출"],"body_sections":[{"heading_ko":"절차의 시작과 효력","paragraphs_ko":["신청은 법원 절차를 시작하는 행위이고, 법이 정한 대항력·우선변제권 유지 효과는 임차권등기가 마쳐진 때를 기준으로 합니다."]},{"heading_ko":"실무 확인","paragraphs_ko":["결정문만 보지 말고 실제 등기부에 임차권등기가 기입됐는지 확인해야 합니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-04"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-04"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.housing-lease-ko-0003-03"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.provisional-attachment-vs-property-disclosure"]},
    {"content_id":"content.report-vs-complaint-vs-accusation","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"report-vs-complaint-vs-accusation","title_ko":"신고·고소·고발은 어떻게 다른가요?","one_line_answer_ko":"누가 어떤 의사로 수사기관에 알리는지에 따라 일반 신고, 피해자 등의 고소, 제3자의 고발로 구분됩니다.","audience_situation_ko":"범죄 피해나 범죄 의심 사실을 경찰·검찰에 알리려는 경우","key_points_ko":["피해자 등 고소권자 여부를 확인합니다.","고발은 누구든지 할 수 있지만 공무원은 직무상 범죄를 알면 의무가 문제 됩니다.","고소·고발은 서면 또는 구술로 검사나 사법경찰관에게 합니다."],"action_steps_ko":["제출자의 지위를 적습니다.","범죄사실과 원하는 조치를 명확히 씁니다.","접수증과 제출본을 보관합니다."],"facts_to_check_ko":["피해자와 제출자의 관계","처벌을 원하는 의사","제출기관과 접수형식"],"caution_ko":"문서 제목보다 내용과 제출자의 법적 지위가 중요합니다.","search_intents_ko":["신고 고소 차이","고발 고소 차이","고소장 제출 방법"],"body_sections":[{"heading_ko":"주체가 다릅니다","paragraphs_ko":["고소는 범죄 피해자 등 법이 정한 사람이 할 수 있고, 고발은 범죄가 있다고 생각하는 누구든지 할 수 있습니다."]},{"heading_ko":"형식도 확인합니다","paragraphs_ko":["고소와 고발은 서면 또는 구술로 검사 또는 사법경찰관에게 해야 하며, 구술이면 조서를 작성합니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-05"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-05"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.criminal-procedure-ko-0223","coord.legal-concept-comparisons-02.criminal-procedure-ko-0234","coord.legal-concept-comparisons-02.criminal-procedure-ko-0237"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.crime-victim-relief-fund-vs-civil-damages"]},
    {"content_id":"content.divorce-agreement-vs-effective-divorce","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"divorce-agreement-vs-effective-divorce","title_ko":"이혼합의서에 서명하면 이혼한 건가요?","one_line_answer_ko":"아닙니다. 가정법원의 협의이혼의사 확인을 받고 법정 신고까지 해야 협의이혼의 효력이 생깁니다.","audience_situation_ko":"부부가 이혼과 재산 문제를 합의해 문서에 서명한 경우","key_points_ko":["사적 합의서와 신분상 이혼 성립은 다릅니다.","가정법원 확인과 신고가 모두 필요합니다.","미성년 자녀가 있으면 양육·친권 관련 서류도 확인합니다."],"action_steps_ko":["협의이혼 안내와 확인 절차를 밟습니다.","자녀 관련 협의 또는 심판 자료를 준비합니다.","확인서 등본으로 기한 안에 신고합니다."],"facts_to_check_ko":["가정법원 확인 여부","이혼신고 수리 여부","미성년 자녀와 양육 합의"],"caution_ko":"합의서가 재산 문제의 증거가 될 수 있어도 그 자체로 가족관계등록부상 혼인을 끝내지는 않습니다.","search_intents_ko":["이혼합의서 효력","협의이혼 신고","이혼 법원 확인"],"body_sections":[{"heading_ko":"신분상 효력의 요건","paragraphs_ko":["민법은 가정법원의 확인을 받아 가족관계등록법에 따라 신고해야 협의이혼의 효력이 생긴다고 정합니다."]},{"heading_ko":"합의서의 역할","paragraphs_ko":["재산분할·양육 등에 관한 합의와 혼인관계 종료의 법정 절차는 구분해 관리해야 합니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-06"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-06"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0836","coord.legal-concept-comparisons-02.civil-act-ko-0836-02"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.contract-rescission-vs-cancellation"]},
    {"content_id":"content.loan-obligation-vs-guarantee-obligation","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"loan-obligation-vs-guarantee-obligation","title_ko":"돈을 빌린 사람과 보증한 사람의 책임은 같나요?","one_line_answer_ko":"차용인은 직접 반환할 주채무를 지고, 보증인은 적법한 보증약정 아래 주채무자가 이행하지 않을 때 보증채무를 집니다.","audience_situation_ko":"차용증이나 보증서에 이름을 적어 자신의 책임 범위를 알고 싶은 경우","key_points_ko":["누가 돈을 실제로 받았는지 확인합니다.","보증은 서명 있는 서면 등 법정 방식이 핵심입니다.","보증 범위와 주채무의 변제기를 따로 봅니다."],"action_steps_ko":["송금내역과 차용증을 대조합니다.","보증문구·서명·최고액을 확인합니다.","주채무의 잔액과 불이행 시점을 계산합니다."],"facts_to_check_ko":["차용금 수령자","보증서 작성 방식","보증 범위와 주채무 잔액"],"caution_ko":"가족이나 회사 관계자라는 이유만으로 당연히 보증책임이 생기는 것은 아닙니다.","search_intents_ko":["대여금 보증 차이","보증서 효력","주채무 보증채무"],"body_sections":[{"heading_ko":"채무의 출발점","paragraphs_ko":["소비대차는 돈 등을 이전하고 같은 종류·수량으로 반환하기로 약정하는 계약입니다. 보증채무는 주채무자가 이행하지 않을 때 대신 이행하는 별도 채무입니다."]},{"heading_ko":"보증 방식","paragraphs_ko":["보증의사는 보증인이 서명한 서면 등 법정 방식으로 표시되어야 효력이 문제 됩니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-07"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-07"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0598","coord.legal-concept-comparisons-02.civil-act-ko-0428","coord.legal-concept-comparisons-02.civil-act-ko-0428-02"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.contractual-interest-vs-default-damages"]},
    {"content_id":"content.contractual-interest-vs-default-damages","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"contractual-interest-vs-default-damages","title_ko":"약정이자와 지연손해금은 같은 돈인가요?","one_line_answer_ko":"약정이자는 돈 사용의 대가이고 지연손해금은 변제기 뒤 미지급에 대한 배상이므로 시작일과 적용 이율을 나눠 계산합니다.","audience_situation_ko":"빌려준 돈의 이자와 연체금을 계산하려는 경우","key_points_ko":["이자 약정의 존재와 상한을 확인합니다.","확정기한이 있으면 기한 다음 단계의 지체 여부를 봅니다.","지연손해금의 약정률과 법정률 적용을 구분합니다."],"action_steps_ko":["원금·약정이율·변제기를 표로 정리합니다.","변제기 전후 기간을 나눕니다.","일부 변제가 있으면 날짜별 원금을 다시 계산합니다."],"facts_to_check_ko":["이자 약정과 상한","변제기 또는 이행청구일","일부 변제 내역"],"caution_ko":"계약서의 연 이율을 모든 기간에 기계적으로 곱하면 과다 또는 과소 계산될 수 있습니다.","search_intents_ko":["약정이자 지연손해금 차이","연체이자 계산","대여금 지연손해금"],"body_sections":[{"heading_ko":"발생 근거가 다릅니다","paragraphs_ko":["약정이자는 금전 사용의 대가이고, 지연손해금은 금전채무의 이행지체로 생기는 손해배상입니다."]},{"heading_ko":"계산 순서","paragraphs_ko":["원금, 이자 약정, 변제기, 지체 개시일, 일부 변제를 순서대로 확인하고 기간별 적용률을 나눕니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-08"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-08"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0379","coord.legal-concept-comparisons-02.civil-act-ko-0387","coord.legal-concept-comparisons-02.civil-act-ko-0397","coord.legal-concept-comparisons-02.interest-limit-ko-0002"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.loan-obligation-vs-guarantee-obligation","content.certified-demand-vs-judicial-claim"]},
    {"content_id":"content.provisional-attachment-vs-property-disclosure","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"provisional-attachment-vs-property-disclosure","title_ko":"가압류와 재산명시는 언제 쓰나요?","one_line_answer_ko":"가압류는 판결 전후 장래 집행을 보전하고, 재산명시는 집행권원을 가진 뒤 채무자의 재산목록을 확보하는 절차입니다.","audience_situation_ko":"채무자가 재산을 빼돌릴까 걱정되거나 판결 뒤 재산을 찾지 못한 경우","key_points_ko":["가압류는 보전처분입니다.","재산명시는 집행권원과 집행개시 요건을 전제로 합니다.","재산을 묶는 것과 재산목록을 밝히는 것은 목적이 다릅니다."],"action_steps_ko":["현재 집행권원 보유 여부를 확인합니다.","보전할 구체적 재산이나 재산 파악 필요성을 정리합니다.","각 절차에 필요한 소명자료와 서류를 준비합니다."],"facts_to_check_ko":["집행권원 보유","채무자 재산의 종류","재산 처분 위험"],"caution_ko":"재산명시 신청 자체가 특정 재산을 압류하거나 현금화하는 것은 아닙니다.","search_intents_ko":["가압류 재산명시 차이","판결 전 재산 보전","채무자 재산 찾기"],"body_sections":[{"heading_ko":"보전과 탐색의 차이","paragraphs_ko":["가압류는 장래 강제집행이 어려워지는 것을 막기 위해 재산을 보전합니다. 재산명시는 일정한 집행권원을 가진 채권자가 재산목록 제출을 요구합니다."]},{"heading_ko":"절차 단계","paragraphs_ko":["아직 판결 전이고 처분 위험이 큰지, 이미 집행권원이 있지만 재산을 모르는지에 따라 출발 절차가 달라집니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-09"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-09"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-execution-ko-0276","coord.legal-concept-comparisons-02.civil-execution-ko-0061"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.lease-registration-application-vs-completion"]},
    {"content_id":"content.crime-victim-relief-fund-vs-civil-damages","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T12:00:00+00:00","expires_at":"2026-10-21T12:00:00+00:00","slug":"crime-victim-relief-fund-vs-civil-damages","title_ko":"범죄피해 구조금과 민사 손해배상은 무엇이 다른가요?","one_line_answer_ko":"구조금은 법정 요건에 따라 국가에 신청하고, 민사 손해배상은 불법행위 요건을 입증해 가해자에게 청구합니다.","audience_situation_ko":"강력범죄 피해 뒤 가해자에게 당장 배상받기 어렵거나 국가 지원을 알아보는 경우","key_points_ko":["구조금은 국가의 법정 구조제도입니다.","신청은 범죄피해 발생을 안 날부터 3년, 발생일부터 10년 제한을 확인합니다.","민사청구는 가해자의 책임과 손해 범위를 입증합니다."],"action_steps_ko":["피해 유형과 치료·소득 자료를 확보합니다.","구조금 신청기간을 먼저 계산합니다.","가해자 상대 민사청구의 증거와 집행 가능성을 별도로 검토합니다."],"facts_to_check_ko":["사망·장해·중상해 해당 여부","범죄피해를 안 날과 발생일","가해자의 위법행위와 손해액"],"caution_ko":"구조금과 민사배상은 요건과 상대방이 다르며, 다른 급여·배상과의 조정 문제도 신청 단계에서 확인해야 합니다.","search_intents_ko":["범죄피해 구조금","범죄피해 민사소송","구조금 신청기간"],"body_sections":[{"heading_ko":"청구 상대가 다릅니다","paragraphs_ko":["구조금은 법이 정한 범죄피해에 대해 국가가 심사해 지급하는 제도이고, 민사 손해배상은 가해자에게 책임을 묻는 절차입니다."]},{"heading_ko":"기간과 입증","paragraphs_ko":["구조금은 법정 신청기간과 피해 유형을, 민사청구는 고의·과실, 위법성, 손해와 인과관계를 각각 확인해야 합니다."]}],"rule_ids":["rule.legal-concept-comparisons-02.comparison-10"],"scenario_ids":["scenario.legal-concept-comparisons-02.comparison-10"],"source_coordinate_ids":["coord.legal-concept-comparisons-02.crime-victim-protection-ko-0016","coord.legal-concept-comparisons-02.crime-victim-protection-ko-0025","coord.legal-concept-comparisons-02.civil-act-ko-0750"],"hub_ids":["hub.legal-concept-comparisons-02"],"related_content_ids":["content.report-vs-complaint-vs-accusation"]}
  ]
}
