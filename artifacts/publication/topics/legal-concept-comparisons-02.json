  "rule_cards": [
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-01","title_ko":"계약 해제와 취소의 출발점","proposition_ko":"해제는 성립한 계약의 채무불이행 등 해제사유를, 취소는 착오·사기·강박 등 의사표시의 흠을 따지므로 근거와 제3자 보호 규정이 다릅니다.","norm":{"actor_ko":"계약 당사자 또는 취소권자","conditions_ko":"채무불이행에 따른 해제요건 또는 의사표시 하자에 따른 취소요건 충족","legal_effect_ko":"각 제도의 요건에 따라 계약관계를 소급적으로 해소하거나 의사표시를 취소"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0109","coord.legal-concept-comparisons-02.civil-act-ko-0110","coord.legal-concept-comparisons-02.civil-act-ko-0544","coord.legal-concept-comparisons-02.civil-act-ko-0548"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-02","title_ko":"가계약금과 해약금","proposition_ko":"가계약금은 법률이 정한 독립 유형이 아니므로 계약 성립과 지급금의 기능을 먼저 확인해야 하며, 민법 제565조의 해약금 해제는 별도 약정이 없고 이행 착수 전인 경우가 기준입니다.","norm":{"actor_ko":"매매 당사자","conditions_ko":"목적물·대금 합의 여부, 지급금의 성격, 이행 착수 여부 확인","legal_effect_ko":"계약 성립 여부와 해약금 약정 인정 여부에 따라 반환·배액상환 또는 계약이행 문제로 분기"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0563","coord.legal-concept-comparisons-02.civil-act-ko-0565"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-03","title_ko":"최고와 재판상 청구의 시효 효과","proposition_ko":"내용증명으로 한 최고만으로 시효 효과가 완결되는 것은 아니며, 최고 뒤 6개월 안에 재판상 청구 등 법정 조치를 이어야 합니다.","norm":{"actor_ko":"권리 행사자","conditions_ko":"최고 후 6개월 안에 재판상 청구 등 후속조치 여부","legal_effect_ko":"후속조치가 있으면 최고 시점의 시효 효과를 보전할 수 있으나 없으면 최고만의 효과를 잃음"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0170","coord.legal-concept-comparisons-02.civil-act-ko-0174"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-04","title_ko":"임차권등기 신청과 등기 완료","proposition_ko":"임차권등기명령 신청은 절차의 시작이고, 이사 뒤 대항력·우선변제권을 유지하는 법정 효과는 임차권등기가 마쳐진 때를 기준으로 판단합니다.","norm":{"actor_ko":"보증금을 돌려받지 못한 임차인","conditions_ko":"임대차 종료와 보증금 미반환, 임차권등기 완료 여부","legal_effect_ko":"등기 완료 후 이사하더라도 종전 대항력·우선변제권을 유지하거나 새로 취득"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.housing-lease-ko-0003-03"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-05","title_ko":"신고·고소·고발의 주체와 의미","proposition_ko":"범죄 신고는 수사기관에 사실을 알리는 일반 행위이고, 고소는 피해자 등 고소권자가, 고발은 누구든지 범죄가 있다고 판단할 때 할 수 있는 법정 절차입니다.","norm":{"actor_ko":"신고자, 피해자 등 고소권자, 또는 고발자","conditions_ko":"행위자의 법적 지위와 제출 의사·방식 확인","legal_effect_ko":"수사 단서 제공 또는 고소·고발 절차로 접수되며 각 지위에 따른 후속 권리가 달라짐"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.criminal-procedure-ko-0223","coord.legal-concept-comparisons-02.criminal-procedure-ko-0234","coord.legal-concept-comparisons-02.criminal-procedure-ko-0237"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-06","title_ko":"이혼 합의와 협의이혼 성립","proposition_ko":"이혼합의서에 서명한 것만으로 혼인관계가 끝나지 않으며, 가정법원의 확인을 받아 법정 신고를 해야 협의이혼의 효력이 생깁니다.","norm":{"actor_ko":"협의이혼하려는 부부","conditions_ko":"법정 안내·숙려 절차, 가정법원 확인, 이혼신고","legal_effect_ko":"법정 신고가 수리되어야 협의이혼의 신분상 효력 발생"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0836","coord.legal-concept-comparisons-02.civil-act-ko-0836-02"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-07","title_ko":"대여금채무와 보증채무","proposition_ko":"차용인은 빌린 돈을 돌려줄 주채무를 지고, 보증인은 주채무자가 이행하지 않을 때 대신 이행할 채무를 지며 보증의사는 법정 방식으로 표시되어야 합니다.","norm":{"actor_ko":"차용인과 보증인","conditions_ko":"소비대차 합의 또는 서면 등 법정 방식의 보증의사 확인","legal_effect_ko":"차용인은 원금 반환채무, 보증인은 주채무 불이행을 전제로 한 보증채무 부담"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0598","coord.legal-concept-comparisons-02.civil-act-ko-0428","coord.legal-concept-comparisons-02.civil-act-ko-0428-02"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-08","title_ko":"약정이자와 지연손해금","proposition_ko":"약정이자는 돈을 사용하는 기간의 대가이고, 지연손해금은 변제기가 지난 뒤 금전채무를 이행하지 않은 데 따른 손해배상으로 발생 근거와 시작일을 따로 계산합니다.","norm":{"actor_ko":"금전채무자와 채권자","conditions_ko":"이자 약정 유무, 이자 상한, 변제기와 지체 개시일 확인","legal_effect_ko":"사용기간 이자와 지체기간 손해배상을 각 근거·기간·적용률에 따라 산정"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-act-ko-0379","coord.legal-concept-comparisons-02.civil-act-ko-0387","coord.legal-concept-comparisons-02.civil-act-ko-0397","coord.legal-concept-comparisons-02.interest-limit-ko-0002"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-09","title_ko":"가압류와 재산명시","proposition_ko":"가압류는 장래 강제집행을 보전하는 절차이고, 재산명시는 집행권원을 가진 채권자가 채무자의 재산목록 제출을 요구하는 절차입니다.","norm":{"actor_ko":"금전채권자","conditions_ko":"가압류의 보전 필요 또는 재산명시의 집행권원·집행개시 요건 확인","legal_effect_ko":"재산 처분을 보전하거나 채무자의 재산목록을 확보"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.civil-execution-ko-0276","coord.legal-concept-comparisons-02.civil-execution-ko-0061"]},
    {"rule_id":"rule.legal-concept-comparisons-02.comparison-10","title_ko":"범죄피해 구조금과 민사 손해배상","proposition_ko":"범죄피해 구조금은 법정 요건과 신청기간에 따라 국가에 신청하는 제도이고, 민사 손해배상은 가해자의 고의·과실과 위법행위·손해 등을 근거로 가해자에게 청구합니다.","norm":{"actor_ko":"범죄피해자 또는 유족","conditions_ko":"구조금 지급요건·신청기간 또는 불법행위 손해배상 요건 확인","legal_effect_ko":"국가의 구조금 지급 심사 또는 가해자의 민사상 배상책임 판단"},"source_coordinate_ids":["coord.legal-concept-comparisons-02.crime-victim-protection-ko-0016","coord.legal-concept-comparisons-02.crime-victim-protection-ko-0025","coord.legal-concept-comparisons-02.civil-act-ko-0750"]}
