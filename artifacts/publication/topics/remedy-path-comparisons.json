  "content_entries":[
    {"content_id":"content.administrative-appeal-vs-revocation-lawsuit","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"administrative-appeal-vs-revocation-lawsuit","title_ko":"행정심판과 취소소송 중 어디에 먼저 가야 하나요?","one_line_answer_ko":"법률이 심판전치를 특별히 요구하지 않으면 반드시 행정심판부터 할 필요는 없지만, 기관·기간·절차 효과를 비교해 선택해야 합니다.","audience_situation_ko":"영업정지·자격취소 등 행정처분에 불복하려는 경우","key_points_ko":["행정심판은 위원회, 취소소송은 법원이 판단합니다.","특별법상 심판전치 여부를 먼저 확인합니다.","청구기간과 제소기간을 각각 계산합니다."],"action_steps_ko":["처분서와 고지문을 확보합니다.","처분을 안 날과 처분일을 적습니다.","특별법상 전치절차와 원하는 구제효과를 확인합니다."],"facts_to_check_ko":["처분의 법적 근거","처분 인지일","심판전치 규정"],"caution_ko":"행정심판을 제기했다는 이유로 취소소송 제소기간이 언제나 무제한 늘어나는 것은 아닙니다.","search_intents_ko":["행정심판 행정소송 차이","취소소송 먼저","행정처분 불복"],"body_sections":[{"heading_ko":"판단기관과 목적","paragraphs_ko":["행정심판은 행정심판위원회가 처분의 위법·부당을 심사하고, 취소소송은 법원이 처분의 위법성을 판단합니다."]},{"heading_ko":"기간을 따로 계산","paragraphs_ko":["각 절차의 기산점과 장기 제한기간이 다르므로 처분서 수령일부터 동시에 계산해야 합니다."]}],"rule_ids":["rule.remedy-path-comparisons.01"],"scenario_ids":["scenario.remedy-path-comparisons.01"],"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-appeals-ko-0005","coord.remedy-path-comparisons.administrative-appeals-ko-0027","coord.remedy-path-comparisons.administrative-litigation-ko-0018","coord.remedy-path-comparisons.administrative-litigation-ko-0020"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.administrative-appeal-suspension-vs-court-suspension","content.revocation-lawsuit-vs-state-compensation","content.admin-appeal.application-preparation"]},
    {"content_id":"content.administrative-appeal-suspension-vs-court-suspension","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"administrative-appeal-suspension-vs-court-suspension","title_ko":"행정심판 집행정지와 법원 집행정지는 어떻게 다른가요?","one_line_answer_ko":"본안이 행정심판이면 위원회에, 취소소송이면 법원에 신청하며 본안 제기만으로 처분 집행이 자동 정지되지는 않습니다.","audience_situation_ko":"본안 결론 전에 영업정지 등 처분이 집행될 위험이 있는 경우","key_points_ko":["본안 절차에 따라 신청기관이 다릅니다.","행정심판의 중대한 손해와 취소소송의 회복하기 어려운 손해 등 절차별 요건을 구분합니다.","공공복리에 중대한 영향 등 제한도 확인합니다."],"action_steps_ko":["처분의 예정 집행일을 확인합니다.","손해의 중대성·긴급성과 회복 가능성 자료를 준비합니다.","본안 청구·소송과 함께 집행정지를 신청합니다."],"facts_to_check_ko":["본안 절차","집행 예정일","손해의 긴급성과 회복 가능성"],"caution_ko":"불복서류 접수증만으로 처분 효력이 멈췄다고 생각하면 안 됩니다.","search_intents_ko":["행정심판 집행정지","취소소송 집행정지","영업정지 멈추기"],"body_sections":[{"heading_ko":"자동정지가 아닙니다","paragraphs_ko":["행정심판 청구나 취소소송 제기는 원칙적으로 처분의 효력이나 집행을 자동 정지하지 않습니다."]},{"heading_ko":"본안과 신청기관","paragraphs_ko":["행정심판 단계에서는 위원회, 취소소송 단계에서는 법원에 각 법정 요건을 갖춰 신청합니다."]}],"rule_ids":["rule.remedy-path-comparisons.02"],"scenario_ids":["scenario.remedy-path-comparisons.02"],"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-appeals-ko-0030","coord.remedy-path-comparisons.administrative-litigation-ko-0023"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.administrative-appeal-vs-revocation-lawsuit","content.admin-appeal.application-preparation"]},
    {"content_id":"content.revocation-lawsuit-vs-state-compensation","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"revocation-lawsuit-vs-state-compensation","title_ko":"처분 취소와 국가배상은 같은 구제인가요?","one_line_answer_ko":"취소소송은 위법한 처분을 제거하고, 국가배상은 공무원의 위법한 직무행위로 생긴 손해의 금전배상을 구합니다.","audience_situation_ko":"위법한 행정처분을 없애면서 이미 생긴 손해도 배상받고 싶은 경우","key_points_ko":["처분 제거와 손해 배상은 목적이 다릅니다.","국가배상은 고의·과실과 손해·인과관계를 따로 봅니다.","각 청구의 기간과 피고도 따로 확인합니다."],"action_steps_ko":["처분서와 집행 경위를 정리합니다.","취소 필요성과 금전 손해를 분리합니다.","공무원의 법령 위반과 과실 자료를 확보합니다."],"facts_to_check_ko":["처분 존속 여부","구체적 손해액","공무원의 고의·과실"],"caution_ko":"처분이 취소됐다고 국가배상책임이 자동 인정되거나, 배상을 받았다고 처분이 자동 취소되는 것은 아닙니다.","search_intents_ko":["취소소송 국가배상","위법 처분 손해배상","행정소송 배상"],"body_sections":[{"heading_ko":"구제 목적","paragraphs_ko":["취소소송은 처분의 법적 효력을 다투고, 국가배상은 직무상 위법행위로 발생한 손해를 금전으로 회복하는 절차입니다."]},{"heading_ko":"입증 항목","paragraphs_ko":["국가배상에서는 처분 위법성뿐 아니라 공무원의 고의·과실, 손해와 인과관계를 별도로 살핍니다."]}],"rule_ids":["rule.remedy-path-comparisons.03"],"scenario_ids":["scenario.remedy-path-comparisons.03"],"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-litigation-ko-0002","coord.remedy-path-comparisons.state-compensation-ko-0002"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.administrative-appeal-vs-revocation-lawsuit","content.shared-mobility-public-road-defect"]},
    {"content_id":"content.civil-mediation-vs-civil-lawsuit","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"civil-mediation-vs-civil-lawsuit","title_ko":"민사조정과 민사소송 중 어떤 절차가 맞나요?","one_line_answer_ko":"조건을 조정해 합의할 여지가 크면 민사조정을, 권리관계를 판결로 확정해야 하면 민사소송을 우선 검토합니다.","audience_situation_ko":"돈·계약·손해배상 분쟁을 법원에서 해결하려는 경우","key_points_ko":["조정은 합의 중심, 소송은 판결 중심입니다.","성립한 조정은 재판상 화해와 같은 효력이 있습니다.","조정 불성립 뒤 소송 이행도 고려합니다."],"action_steps_ko":["양보 가능한 조건을 정리합니다.","핵심 증거와 청구금액을 계산합니다.","합의 가능성과 판결 필요성을 비교합니다."],"facts_to_check_ko":["쟁점 수와 증거","상대방의 협상 의사","집행 가능한 결론 필요성"],"caution_ko":"조정에 응했다는 사실만으로 반드시 합의해야 하는 것은 아니지만, 성립한 조정의 효력은 가볍지 않습니다.","search_intents_ko":["민사조정 민사소송 차이","조정 효력","민사 분쟁 절차"],"body_sections":[{"heading_ko":"해결 방식","paragraphs_ko":["조정은 당사자가 수용할 해결안을 찾고, 소송은 주장과 증거를 토대로 법원이 판단합니다."]},{"heading_ko":"결과의 효력","paragraphs_ko":["조정이 성립하면 재판상 화해와 같은 효력이 생기며, 불성립하면 사건이 소송으로 이어질 수 있습니다."]}],"rule_ids":["rule.remedy-path-comparisons.04"],"scenario_ids":["scenario.remedy-path-comparisons.04"],"source_coordinate_ids":["coord.remedy-path-comparisons.civil-mediation-ko-0002","coord.remedy-path-comparisons.civil-mediation-ko-0027","coord.remedy-path-comparisons.civil-mediation-ko-0029","coord.remedy-path-comparisons.civil-procedure-ko-0248"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.payment-order-vs-civil-mediation","content.small-claims-trial-vs-general-civil-lawsuit","content.payment-order-vs-civil-lawsuit"]},
    {"content_id":"content.payment-order-vs-civil-mediation","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"payment-order-vs-civil-mediation","title_ko":"지급명령과 민사조정 중 무엇이 빠른가요?","one_line_answer_ko":"다툼이 적은 정액 금전청구는 지급명령이 맞을 수 있고, 금액·기한을 조정할 여지가 있으면 민사조정이 더 맞을 수 있습니다.","audience_situation_ko":"빌려준 돈이나 미지급 대금을 신속히 받으려는 경우","key_points_ko":["지급명령은 금전·대체물 등 청구에 한정됩니다.","채무자가 이의하면 소송으로 넘어갑니다.","민사조정은 합의안을 만들 수 있습니다."],"action_steps_ko":["채권액과 근거자료를 확정합니다.","상대방 주소와 다툼 가능성을 확인합니다.","분할지급 등 협상 필요성을 판단합니다."],"facts_to_check_ko":["청구 종류","송달 가능한 주소","상대방 이의 가능성"],"caution_ko":"상대방이 적극 다툴 것이 분명하면 지급명령의 속도 이점이 사라질 수 있습니다.","search_intents_ko":["지급명령 민사조정 차이","돈 받는 빠른 절차","지급명령 이의"],"body_sections":[{"heading_ko":"지급명령이 맞는 경우","paragraphs_ko":["청구액과 근거가 분명하고 상대방이 다투지 않을 가능성이 큰 금전청구에 적합할 수 있습니다."]},{"heading_ko":"조정이 맞는 경우","paragraphs_ko":["분할지급, 이행기 연장 등 당사자 사이에 조건을 조정해야 한다면 민사조정의 장점이 큽니다."]}],"rule_ids":["rule.remedy-path-comparisons.05"],"scenario_ids":["scenario.remedy-path-comparisons.05"],"source_coordinate_ids":["coord.remedy-path-comparisons.civil-procedure-ko-0462","coord.remedy-path-comparisons.civil-procedure-ko-0470","coord.remedy-path-comparisons.civil-mediation-ko-0002","coord.remedy-path-comparisons.civil-mediation-ko-0029"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.civil-mediation-vs-civil-lawsuit","content.small-claims-trial-vs-general-civil-lawsuit","content.when-payment-order-fits","content.payment-order-objection-two-weeks"]},
    {"content_id":"content.small-claims-trial-vs-general-civil-lawsuit","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"small-claims-trial-vs-general-civil-lawsuit","title_ko":"소액사건재판과 일반 민사소송은 무엇이 다른가요?","one_line_answer_ko":"법정 범위의 금전 등 청구에는 소액사건 특례가 적용되고, 범위를 벗어나거나 복잡한 청구는 일반 민사소송 절차가 기준입니다.","audience_situation_ko":"비교적 적은 금액의 대금·손해배상을 청구하려는 경우","key_points_ko":["청구 종류와 소송목적 값을 먼저 봅니다.","소액사건에는 간이·신속한 특례가 있습니다.","적은 금액이라고 모든 사건이 자동으로 단순해지는 것은 아닙니다."],"action_steps_ko":["원금·이자·부대청구를 구분합니다.","현재 법정 소액범위를 확인합니다.","쟁점과 증거의 복잡성을 정리합니다."],"facts_to_check_ko":["청구 종류","소송목적 값","쟁점·증거 수"],"caution_ko":"소액 기준 금액은 현재 규정을 확인해야 하며 청구를 인위적으로 나누는 방식은 별도 문제가 될 수 있습니다.","search_intents_ko":["소액사건 민사소송 차이","소액재판 범위","소액 손해배상"],"body_sections":[{"heading_ko":"적용범위","paragraphs_ko":["소액사건심판법은 일정한 금전·대체물·유가증권 급부 청구에 특례를 적용합니다."]},{"heading_ko":"절차 선택","paragraphs_ko":["청구액뿐 아니라 청구의 종류, 당사자 수, 감정 등 증거조사의 필요성도 함께 봐야 합니다."]}],"rule_ids":["rule.remedy-path-comparisons.06"],"scenario_ids":["scenario.remedy-path-comparisons.06"],"source_coordinate_ids":["coord.remedy-path-comparisons.small-claims-trial-ko-0002","coord.remedy-path-comparisons.civil-procedure-ko-0248"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.civil-mediation-vs-civil-lawsuit","content.payment-order-vs-civil-mediation","content.payment-order-vs-civil-lawsuit"]},
    {"content_id":"content.industrial-accident-benefits-vs-civil-damages","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"industrial-accident-benefits-vs-civil-damages","title_ko":"산재보험급여와 민사 손해배상은 함께 받을 수 있나요?","one_line_answer_ko":"두 제도는 요건이 다르고 병행 검토할 수 있지만 같은 사유의 같은 손해에 대해서는 지급액 조정 규정을 확인해야 합니다.","audience_situation_ko":"업무 중 다쳐 산재급여와 회사·제3자 상대 배상을 함께 알아보는 경우","key_points_ko":["산재보험급여는 업무상 재해 인정이 출발점입니다.","민사배상은 사용자·제3자의 책임요건을 따로 봅니다.","같은 손해의 중복 전보를 조정합니다."],"action_steps_ko":["재해 경위와 업무관련성을 정리합니다.","보험급여 항목과 지급액을 모읍니다.","책임주체의 과실과 추가 손해를 구분합니다."],"facts_to_check_ko":["업무상 재해 인정","책임주체와 과실","급여·손해 항목별 금액"],"caution_ko":"산재 승인을 받았다는 사실만으로 회사의 민사상 과실책임이 자동 인정되는 것은 아닙니다.","search_intents_ko":["산재 민사손해배상","산재급여 중복","업무상 재해 회사 책임"],"body_sections":[{"heading_ko":"요건이 다릅니다","paragraphs_ko":["산재보험은 업무상 재해를 사회보험으로 보상하고, 민사배상은 사용자나 제3자의 법적 책임을 전제로 합니다."]},{"heading_ko":"항목별 조정","paragraphs_ko":["치료비·휴업손해 등 같은 사유의 손해에 이미 지급된 보험급여가 있으면 민사배상과의 조정범위를 확인합니다."]}],"rule_ids":["rule.remedy-path-comparisons.07"],"scenario_ids":["scenario.remedy-path-comparisons.07"],"source_coordinate_ids":["coord.remedy-path-comparisons.industrial-accident-compensation-insurance-act-ko-0080","coord.remedy-path-comparisons.civil-act-ko-0750"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.unjust-enrichment-vs-tort-damages","content.accident-damages-responsibility-map"]},
    {"content_id":"content.summary-order-vs-formal-trial","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"summary-order-vs-formal-trial","title_ko":"약식명령과 정식재판은 무엇이 다른가요?","one_line_answer_ko":"약식명령은 공판 없이 벌금 등을 명하고, 불복하려면 고지받은 날부터 7일 안에 정식재판을 청구해야 합니다.","audience_situation_ko":"법원에서 벌금 약식명령을 받고 사실이나 양형을 다투려는 경우","key_points_ko":["약식명령은 서면 중심의 간이절차입니다.","정식재판은 공판에서 주장·증거를 다툽니다.","7일 청구기간이 핵심입니다."],"action_steps_ko":["약식명령 고지일을 확인합니다.","다툴 사실·법률·양형 사유를 정리합니다.","7일 안에 법원에 정식재판을 청구합니다."],"facts_to_check_ko":["고지일","명령 내용","불복 사유"],"caution_ko":"검찰의 구약식 처분 통지와 법원의 약식명령 고지는 구분해야 하며 기간은 법원 고지를 기준으로 확인합니다.","search_intents_ko":["약식명령 정식재판","벌금 불복 7일","구약식 약식명령 차이"],"body_sections":[{"heading_ko":"절차 차이","paragraphs_ko":["약식명령은 공판을 열지 않고 서면으로 벌금·과료·몰수 등을 명할 수 있는 절차입니다."]},{"heading_ko":"불복 방법","paragraphs_ko":["피고인이나 검사는 약식명령 고지를 받은 날부터 7일 안에 정식재판을 청구할 수 있습니다."]}],"rule_ids":["rule.remedy-path-comparisons.08"],"scenario_ids":["scenario.remedy-path-comparisons.08"],"source_coordinate_ids":["coord.remedy-path-comparisons.criminal-procedure-ko-0448","coord.remedy-path-comparisons.criminal-procedure-ko-0453"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":[]},
    {"content_id":"content.civil-appeal-vs-supreme-appeal","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"civil-appeal-vs-supreme-appeal","title_ko":"민사 항소와 상고는 어떻게 다른가요?","one_line_answer_ko":"항소는 제1심 판결을 다시 다투고, 상고는 항소심 판결의 법령 위반 등 법정 상고이유를 대법원에서 다툽니다.","audience_situation_ko":"민사판결 결과에 불복해 다음 심급을 검토하는 경우","key_points_ko":["항소와 상고는 대상 판결의 심급이 다릅니다.","상고심은 사실관계를 처음부터 다시 판단하는 심급이 아닙니다.","불복기간과 제출법원을 즉시 확인합니다."],"action_steps_ko":["판결문 송달일을 기록합니다.","불복 대상이 사실인정인지 법령위반인지 나눕니다.","판결한 법원에 불복장을 기간 안에 제출합니다."],"facts_to_check_ko":["판결 심급","판결문 송달일","불복 쟁점의 성격"],"caution_ko":"상고이유를 단순히 제1심부터의 사실주장을 반복하는 방식으로 구성하면 법정 심리범위와 맞지 않을 수 있습니다.","search_intents_ko":["항소 상고 차이","민사 상고이유","민사판결 불복"],"body_sections":[{"heading_ko":"심급 차이","paragraphs_ko":["항소는 제1심 종국판결에 대한 불복이고, 상고는 고등법원 등 항소심 종국판결에 대한 불복입니다."]},{"heading_ko":"심리범위 차이","paragraphs_ko":["상고심에서는 판결에 영향을 미친 헌법·법률·명령·규칙 위반 등 법정 상고이유가 중심입니다."]}],"rule_ids":["rule.remedy-path-comparisons.09"],"scenario_ids":["scenario.remedy-path-comparisons.09"],"source_coordinate_ids":["coord.remedy-path-comparisons.civil-procedure-ko-0390","coord.remedy-path-comparisons.civil-procedure-ko-0423"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":[]},
    {"content_id":"content.unjust-enrichment-vs-tort-damages","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T17:00:00+00:00","expires_at":"2026-10-21T17:00:00+00:00","slug":"unjust-enrichment-vs-tort-damages","title_ko":"부당이득반환과 손해배상은 무엇이 다른가요?","one_line_answer_ko":"부당이득은 법률상 원인 없는 이익의 반환을, 불법행위 손해배상은 고의·과실의 위법행위로 생긴 손해의 배상을 구합니다.","audience_situation_ko":"잘못 송금했거나 상대방의 위법행위로 돈을 잃어 반환청구 근거를 고르는 경우","key_points_ko":["부당이득은 상대방의 이익과 내 손실을 봅니다.","불법행위는 고의·과실과 위법성까지 봅니다.","같은 금액을 두 번 회수할 수는 없습니다."],"action_steps_ko":["돈이나 재산이 이동한 경위를 정리합니다.","계약 등 법률상 원인이 있었는지 확인합니다.","상대방 행위의 위법성과 과실 증거를 분리합니다."],"facts_to_check_ko":["상대방의 이익","법률상 원인","위법행위와 손해"],"caution_ko":"계약이 유효한데 단순히 결과가 불만족스럽다는 이유만으로 부당이득이 되는 것은 아닙니다.","search_intents_ko":["부당이득 손해배상 차이","잘못 송금 반환","불법행위 반환청구"],"body_sections":[{"heading_ko":"입증할 사실","paragraphs_ko":["부당이득은 법률상 원인 없는 이득과 그로 인한 손실을, 불법행위는 고의·과실, 위법성, 손해와 인과관계를 입증합니다."]},{"heading_ko":"청구 범위","paragraphs_ko":["한 사건에서 두 근거를 함께 검토할 수 있어도 같은 손실을 중복해 회복할 수는 없습니다."]}],"rule_ids":["rule.remedy-path-comparisons.10"],"scenario_ids":["scenario.remedy-path-comparisons.10"],"source_coordinate_ids":["coord.remedy-path-comparisons.civil-act-ko-0741","coord.remedy-path-comparisons.civil-act-ko-0750"],"hub_ids":["hub.remedy-path-comparisons"],"related_content_ids":["content.industrial-accident-benefits-vs-civil-damages","content.what-accident-damages-can-be-claimed","content.negligence-and-causation-in-accidents"]}
  ]
