  "topic_hubs":[{"hub_id":"hub.remedy-path-comparisons","slug":"remedy-path-comparisons","title_ko":"어떤 구제절차를 선택해야 하나요?","summary_ko":"같은 문제에서도 목적·기관·기한·효과가 다른 구제절차를 비교해 첫 선택을 돕습니다.","content_ids":["content.administrative-appeal-vs-revocation-lawsuit","content.administrative-appeal-suspension-vs-court-suspension","content.revocation-lawsuit-vs-state-compensation","content.civil-mediation-vs-civil-lawsuit","content.payment-order-vs-civil-mediation","content.small-claims-trial-vs-general-civil-lawsuit","content.industrial-accident-benefits-vs-civil-damages","content.summary-order-vs-formal-trial","content.civil-appeal-vs-supreme-appeal","content.unjust-enrichment-vs-tort-damages"]}],
  "rule_cards":[
    {"rule_id":"rule.remedy-path-comparisons.01","title_ko":"행정심판과 취소소송의 선택","proposition_ko":"행정심판은 행정심판위원회에 처분의 취소·변경 등을 구하고, 취소소송은 법원에 위법한 처분의 취소를 구하는 절차이며 법률이 특별히 정하지 않으면 심판을 먼저 거치지 않고 소송을 제기할 수 있습니다.","norm":{"actor_ko":"위법·부당한 처분으로 권리를 침해받은 사람","conditions_ko":"처분성, 청구인·원고 적격, 각 제소·청구기간 확인","legal_effect_ko":"행정심판 재결 또는 법원의 취소판결로 처분의 효력을 다툼"},"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-appeals-ko-0005","coord.remedy-path-comparisons.administrative-appeals-ko-0027","coord.remedy-path-comparisons.administrative-litigation-ko-0018","coord.remedy-path-comparisons.administrative-litigation-ko-0020"]},
    {"rule_id":"rule.remedy-path-comparisons.02","title_ko":"두 집행정지의 신청기관","proposition_ko":"행정심판이나 취소소송을 제기해도 처분 집행은 자동으로 멈추지 않으며, 행정심판에서는 위원회에, 취소소송에서는 법원에 각 법정 요건에 따른 집행정지를 신청합니다.","norm":{"actor_ko":"행정심판 청구인 또는 취소소송 원고","conditions_ko":"행정심판의 중대한 손해 또는 취소소송의 회복하기 어려운 손해와 긴급한 필요 등 각 법정 요건 확인","legal_effect_ko":"위원회 또는 법원이 처분의 효력·집행·절차 속행의 전부 또는 일부를 정지"},"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-appeals-ko-0030","coord.remedy-path-comparisons.administrative-litigation-ko-0023"]},
    {"rule_id":"rule.remedy-path-comparisons.03","title_ko":"처분 취소와 금전배상","proposition_ko":"취소소송은 위법한 처분을 제거하는 절차이고, 국가배상은 공무원이 직무 중 고의 또는 과실로 법령을 위반해 손해를 입힌 경우 금전배상 책임을 묻는 절차이므로 한쪽 결과가 다른 쪽을 자동으로 대신하지 않습니다.","norm":{"actor_ko":"위법한 처분 또는 공무원의 위법한 직무행위로 피해를 입은 사람","conditions_ko":"처분 취소요건 또는 국가배상법상 고의·과실·법령위반·손해·인과관계 확인","legal_effect_ko":"처분 취소 또는 국가·지방자치단체의 손해배상"},"source_coordinate_ids":["coord.remedy-path-comparisons.administrative-litigation-ko-0002","coord.remedy-path-comparisons.state-compensation-ko-0002"]},
    {"rule_id":"rule.remedy-path-comparisons.04","title_ko":"민사조정과 민사소송","proposition_ko":"민사조정은 당사자 양보와 합의를 중심으로 분쟁을 해결하고 성립한 조정은 재판상 화해와 같은 효력이 있으며, 민사소송은 소장으로 시작해 법원이 청구의 당부를 판결합니다.","norm":{"actor_ko":"민사분쟁 당사자","conditions_ko":"합의 가능성, 다툼의 정도, 판결 필요성 확인","legal_effect_ko":"조정 성립 또는 확정된 조정갈음결정, 아니면 법원의 판결"},"source_coordinate_ids":["coord.remedy-path-comparisons.civil-mediation-ko-0002","coord.remedy-path-comparisons.civil-mediation-ko-0027","coord.remedy-path-comparisons.civil-mediation-ko-0029","coord.remedy-path-comparisons.civil-procedure-ko-0248"]},
    {"rule_id":"rule.remedy-path-comparisons.05","title_ko":"지급명령과 민사조정","proposition_ko":"지급명령은 일정한 금전·대체물 청구를 서류심리로 신속히 명령받는 절차이고 채무자가 적법하게 이의하면 소송으로 넘어가며, 민사조정은 합의 가능한 해결안을 찾는 절차입니다.","norm":{"actor_ko":"금전 등을 청구하는 채권자 또는 민사분쟁 당사자","conditions_ko":"청구 종류, 상대방 주소와 다툼 예상, 합의 가능성 확인","legal_effect_ko":"확정 지급명령, 이의 후 소송 이행, 또는 조정 성립"},"source_coordinate_ids":["coord.remedy-path-comparisons.civil-procedure-ko-0462","coord.remedy-path-comparisons.civil-procedure-ko-0470","coord.remedy-path-comparisons.civil-mediation-ko-0002","coord.remedy-path-comparisons.civil-mediation-ko-0029"]},
    {"rule_id":"rule.remedy-path-comparisons.06","title_ko":"소액사건과 일반 민사소송","proposition_ko":"소액사건재판은 법정 범위의 금전·대체물·유가증권 청구에 간이하고 신속한 특례를 적용하고, 그 범위를 벗어나거나 복잡한 청구는 일반 민사소송 절차가 기준입니다.","norm":{"actor_ko":"민사상 급부를 청구하는 사람","conditions_ko":"청구 종류와 소송목적 값, 쟁점·증거의 복잡성 확인","legal_effect_ko":"소액사건 특례 또는 일반 민사소송 절차에 따른 판결"},"source_coordinate_ids":["coord.remedy-path-comparisons.small-claims-trial-ko-0002","coord.remedy-path-comparisons.civil-procedure-ko-0248"]},
    {"rule_id":"rule.remedy-path-comparisons.07","title_ko":"산재보험급여와 민사배상","proposition_ko":"산재보험급여는 업무상 재해에 대한 사회보험 급여이고 민사 손해배상은 사용자나 제3자의 법적 책임을 전제로 하며, 같은 사유의 손해에 대해서는 지급된 급여와 배상 사이의 조정 규정을 확인해야 합니다.","norm":{"actor_ko":"업무상 재해를 입은 근로자 또는 유족","conditions_ko":"업무상 재해 인정요건과 민사책임 요건, 동일 손해 항목 확인","legal_effect_ko":"보험급여 지급과 별도 민사배상 가능 범위를 조정"},"source_coordinate_ids":["coord.remedy-path-comparisons.industrial-accident-compensation-insurance-act-ko-0080","coord.remedy-path-comparisons.civil-act-ko-0750"]},
    {"rule_id":"rule.remedy-path-comparisons.08","title_ko":"약식명령과 정식재판","proposition_ko":"약식명령은 공판절차 없이 벌금·과료·몰수 등을 명하는 절차이고, 피고인이나 검사는 약식명령 고지를 받은 날부터 7일 안에 정식재판을 청구할 수 있습니다.","norm":{"actor_ko":"약식명령을 받은 피고인 또는 검사","conditions_ko":"약식명령 고지일과 7일 청구기간 확인","legal_effect_ko":"약식명령 확정 또는 정식 공판절차로 전환"},"source_coordinate_ids":["coord.remedy-path-comparisons.criminal-procedure-ko-0448","coord.remedy-path-comparisons.criminal-procedure-ko-0453"]},
    {"rule_id":"rule.remedy-path-comparisons.09","title_ko":"민사 항소와 상고","proposition_ko":"항소는 제1심 종국판결을 상급법원에서 다시 다투는 절차이고, 상고는 고등법원 등의 종국판결에 법령 위반 등 상고이유가 있는지를 대법원에서 다투는 절차입니다.","norm":{"actor_ko":"민사판결에 불복하는 당사자","conditions_ko":"불복 대상 판결의 심급과 항소·상고 이유 확인","legal_effect_ko":"제2심의 사실·법률 심리 또는 대법원의 법률심 판단"},"source_coordinate_ids":["coord.remedy-path-comparisons.civil-procedure-ko-0390","coord.remedy-path-comparisons.civil-procedure-ko-0423"]},
    {"rule_id":"rule.remedy-path-comparisons.10","title_ko":"부당이득반환과 불법행위 손해배상","proposition_ko":"부당이득반환은 법률상 원인 없이 얻은 이익과 상대방 손실의 반환을 구하고, 불법행위 손해배상은 고의 또는 과실의 위법행위로 생긴 손해의 배상을 구하므로 입증할 사실과 반환 범위의 출발점이 다릅니다.","norm":{"actor_ko":"재산상 손실 또는 위법행위 손해를 입은 사람","conditions_ko":"법률상 원인 없는 이득·손실 또는 고의·과실·위법성·손해·인과관계 확인","legal_effect_ko":"부당이득 반환 또는 불법행위 손해배상"},"source_coordinate_ids":["coord.remedy-path-comparisons.civil-act-ko-0741","coord.remedy-path-comparisons.civil-act-ko-0750"]}
  ],
