  "topic_hubs":[{"hub_id":"hub.deadline-and-timing-comparisons","slug":"deadline-and-timing-comparisons","title_ko":"놓치면 달라지는 법률기한과 시점 비교","summary_ko":"같은 숫자처럼 보여도 기산점·대상 결정·제출기관·기간 도과 효과가 다른 법률기한을 생활사건별로 비교합니다.","content_ids":["content.administrative-appeal-vs-revocation-suit-deadline","content.online-withdrawal-seven-days-vs-defect-deadline","content.unfair-dismissal-vs-wage-claim-deadline","content.property-division-vs-consolation-deadline","content.inheritance-choice-vs-recovery-claim-deadline","content.payment-order-objection-vs-civil-appeal-deadline","content.summary-order-formal-trial-vs-criminal-appeal-deadline","content.industrial-accident-review-vs-rereview-deadline","content.labor-commission-rereview-vs-lawsuit-deadline","content.compensation-order-vs-crime-victim-relief-deadline"]}],
  "rule_cards":[
    {"rule_id":"rule.deadline-timing.01","title_ko":"행정심판과 취소소송의 90일","proposition_ko":"행정심판은 처분을 안 날부터 90일 및 처분일부터 180일이 기준이고, 취소소송은 처분을 안 날부터 90일 및 처분일부터 1년이 기준이므로 90일이라는 숫자만 같을 뿐 장기 제한과 행정심판 후 기산점이 다릅니다.","norm":{"actor_ko":"행정처분을 다투려는 사람","conditions_ko":"처분 인지일·처분일·재결서 송달일과 특별한 전치 규정 확인","legal_effect_ko":"각 불변기간 안에 행정심판 또는 취소소송 제기"},"source_coordinate_ids":["coord.deadline-timing.administrative-appeals-ko-0027","coord.deadline-timing.administrative-litigation-ko-0020"]},
    {"rule_id":"rule.deadline-timing.02","title_ko":"온라인 청약철회 7일과 계약불일치 기간","proposition_ko":"통상적인 온라인 구매 청약철회는 법정 서면 수령 또는 공급 시점을 기준으로 7일이지만, 표시·광고나 계약과 다른 이행은 공급일부터 3개월 이내이면서 그 사실을 안 날 또는 알 수 있었던 날부터 30일 이내를 확인합니다.","norm":{"actor_ko":"통신판매로 재화나 용역을 구매한 소비자","conditions_ko":"계약서면·공급일·불일치 인지일과 철회 제한사유 확인","legal_effect_ko":"해당 기간 안에 청약철회 의사표시"},"source_coordinate_ids":["coord.deadline-timing.ecommerce-ko-0017"]},
    {"rule_id":"rule.deadline-timing.03","title_ko":"부당해고 3개월과 임금채권 3년","proposition_ko":"부당해고 노동위원회 구제신청은 해고 등이 있었던 날부터 3개월이고, 임금채권은 3년간 행사하지 않으면 시효로 소멸하므로 같은 근로관계 문제라도 권리와 기산점이 다릅니다.","norm":{"actor_ko":"해고 또는 임금체불을 겪은 근로자","conditions_ko":"해고일과 각 임금 지급일, 구하려는 권리 구분","legal_effect_ko":"노동위원회 구제신청 또는 임금채권 행사"},"source_coordinate_ids":["coord.deadline-timing.labor-standards-ko-0028","coord.deadline-timing.labor-standards-ko-0049"]},
    {"rule_id":"rule.deadline-timing.04","title_ko":"재산분할 2년과 위자료 소멸시효","proposition_ko":"이혼 재산분할청구권은 이혼한 날부터 2년이 지나면 소멸하고, 불법행위에 기초한 위자료청구는 손해와 가해자를 안 날부터 3년 및 불법행위일부터 10년의 시효를 각각 확인합니다.","norm":{"actor_ko":"이혼 후 재산분할이나 위자료를 청구하려는 사람","conditions_ko":"이혼 성립일, 손해·가해자 인지일, 불법행위일과 청구 근거 확인","legal_effect_ko":"서로 다른 기간 안에 재산분할 또는 손해배상 청구"},"source_coordinate_ids":["coord.deadline-timing.civil-act-ko-0839-02","coord.deadline-timing.civil-act-ko-0766"]},
    {"rule_id":"rule.deadline-timing.05","title_ko":"상속 선택 3개월과 상속회복 3년·10년","proposition_ko":"승인·한정승인·포기는 상속개시를 안 날부터 3개월이 기준이고, 참칭상속권자의 침해에 대한 상속회복청구는 침해를 안 날부터 3년 및 침해행위일부터 10년이 기준입니다.","norm":{"actor_ko":"상속채무를 정리하거나 침해된 상속권을 회복하려는 상속인","conditions_ko":"상속개시 인지일과 상속권 침해 인지일·행위일을 구분","legal_effect_ko":"상속 선택 신고 또는 상속회복의 소 제기"},"source_coordinate_ids":["coord.deadline-timing.civil-act-ko-1019","coord.deadline-timing.civil-act-ko-0999"]},
    {"rule_id":"rule.deadline-timing.06","title_ko":"지급명령 이의와 민사 항소의 2주","proposition_ko":"지급명령 이의와 민사 항소는 모두 송달일부터 2주인 불변기간이지만, 전자는 지급명령을 소송절차로 넘기는 신청이고 후자는 제1심 판결을 상급심에서 다투는 불복입니다.","norm":{"actor_ko":"지급명령을 받은 채무자 또는 민사 제1심 판결에 불복하는 당사자","conditions_ko":"송달받은 문서가 지급명령인지 판결서인지와 송달일 확인","legal_effect_ko":"지급명령 효력 상실과 소송 이행 또는 항소심 개시"},"source_coordinate_ids":["coord.deadline-timing.civil-procedure-ko-0470","coord.deadline-timing.civil-procedure-ko-0396"]},
    {"rule_id":"rule.deadline-timing.07","title_ko":"약식명령 정식재판과 형사 항소의 7일","proposition_ko":"약식명령을 다투는 정식재판 청구와 제1심 형사판결을 다투는 항소는 모두 7일이지만, 불복 대상과 제출서류가 서로 다른 절차입니다.","norm":{"actor_ko":"약식명령 또는 제1심 형사판결에 불복하는 피고인 등","conditions_ko":"받은 재판이 약식명령인지 공판판결인지와 고지·선고 시점 확인","legal_effect_ko":"정식 공판절차 또는 형사항소심 개시"},"source_coordinate_ids":["coord.deadline-timing.criminal-procedure-ko-0453","coord.deadline-timing.criminal-procedure-ko-0358"]},
    {"rule_id":"rule.deadline-timing.08","title_ko":"산재 심사와 재심사의 각 90일","proposition_ko":"산재보험급여 결정에 대한 심사 청구는 그 결정을 안 날부터 90일이고, 심사 결정에 대한 재심사 청구는 심사 결정을 안 날부터 다시 90일이므로 대상 결정과 기산점을 단계별로 기록해야 합니다.","norm":{"actor_ko":"산재보험급여 결정 또는 심사 결정에 불복하는 사람","conditions_ko":"원결정 통지일, 심사 결정 통지일과 판정위원회 심의 여부 확인","legal_effect_ko":"공단 심사 또는 재심사위원회 재심사 절차 개시"},"source_coordinate_ids":["coord.deadline-timing.industrial-accident-ko-0103","coord.deadline-timing.industrial-accident-ko-0106"]},
    {"rule_id":"rule.deadline-timing.09","title_ko":"노동위원회 재심 10일과 행정소송 15일","proposition_ko":"지방·특별노동위원회 처분의 재심은 송달일부터 10일이고, 중앙노동위원회 처분에 대한 소송은 송달일부터 15일이므로 일반 행정불복 기간으로 계산하면 안 됩니다.","norm":{"actor_ko":"노동위원회 처분에 불복하는 당사자","conditions_ko":"처분기관이 지방·특별노동위원회인지 중앙노동위원회인지와 송달일 확인","legal_effect_ko":"중앙노동위원회 재심 또는 법원 소송 제기"},"source_coordinate_ids":["coord.deadline-timing.labor-commission-ko-0026","coord.deadline-timing.labor-commission-ko-0027"]},
    {"rule_id":"rule.deadline-timing.10","title_ko":"배상명령 신청시점과 범죄피해 구조금 기간","proposition_ko":"배상명령은 형사사건 제1심 또는 제2심 공판의 변론종결 전까지 신청하고, 범죄피해 구조금은 피해 발생을 안 날부터 3년 및 피해 발생일부터 10년의 신청 제한을 확인하므로 대상·요건·기관이 다른 회복수단입니다.","norm":{"actor_ko":"범죄로 신체·재산상 피해를 입은 사람 또는 유족","conditions_ko":"형사재판 진행 단계, 배상명령 대상범죄·손해, 구조금 지급요건과 피해 인지일 확인","legal_effect_ko":"형사재판 배상명령 또는 지구심의회 구조금 심사"},"source_coordinate_ids":["coord.deadline-timing.litigation-promotion-ko-0026","coord.deadline-timing.crime-victim-protection-ko-0025"]}
  ],
  "scenario_branches":[
    {"scenario_id":"scenario.deadline-timing.01","question_ko":"처분을 행정심판위원회에서 다툴 것인가, 법원에서 취소를 구할 것인가?","decision_fact_ko":"처분 인지일·처분일·재결서 송달일과 심판전치 여부","when_true_ko":"90일과 180일 제한을 나누어 행정심판 기간을 계산합니다.","when_false_ko":"90일과 1년 제한 및 행정심판 후 기산점을 계산합니다.","rule_ids":["rule.deadline-timing.01"],"source_coordinate_ids":["coord.deadline-timing.administrative-appeals-ko-0027","coord.deadline-timing.administrative-litigation-ko-0020"]},
