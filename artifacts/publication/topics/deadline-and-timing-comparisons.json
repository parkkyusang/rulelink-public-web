  "content_entries":[
    {"content_id":"content.administrative-appeal-vs-revocation-suit-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"administrative-appeal-vs-revocation-suit-deadline","title_ko":"행정심판과 취소소송은 둘 다 90일인가요?","one_line_answer_ko":"둘 다 안 날부터 90일이 핵심이지만 행정심판은 처분일부터 180일, 취소소송은 처분일부터 1년이라는 별도 제한과 행정심판 후 기산점을 구분해야 합니다.","audience_situation_ko":"허가취소·영업정지·과징금 등 처분을 받고 불복기한을 계산하는 경우","key_points_ko":["90일 숫자만 보고 같은 기간으로 취급하지 않습니다.","처분 인지일과 처분일을 모두 기록합니다.","행정심판 후에는 재결서 송달일이 소송기간에 영향을 줄 수 있습니다."],"action_steps_ko":["처분서와 송달봉투를 보존합니다.","처분을 실제 안 날과 처분일을 따로 적습니다.","심판전치 여부와 남은 기간을 즉시 확인합니다."],"facts_to_check_ko":["처분 인지일","처분일","재결서 송달일","심판전치 여부"],"caution_ko":"무효등확인심판이나 부작위 의무이행심판처럼 기간 규정 적용이 다른 유형도 있으므로 처분 유형을 먼저 확정해야 합니다.","search_intents_ko":["행정심판 90일","취소소송 제소기간","행정처분 불복기한"],"body_sections":[{"heading_ko":"같은 90일, 다른 장기 제한","paragraphs_ko":["행정심판과 취소소송 모두 처분을 안 날부터 90일이 출발점이지만 처분일부터 계산하는 제한은 각각 180일과 1년입니다."]},{"heading_ko":"재결 뒤 소송","paragraphs_ko":["행정심판을 거친 경우에는 재결서 정본 송달일을 기준으로 취소소송 기간이 새로 문제 되는지 확인합니다."]}],"rule_ids":["rule.deadline-timing.01"],"scenario_ids":["scenario.deadline-timing.01"],"source_coordinate_ids":["coord.deadline-timing.administrative-appeals-ko-0027","coord.deadline-timing.administrative-litigation-ko-0020"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.admin-appeal.application-preparation","content.administrative-appeal-vs-revocation-lawsuit"]},
    {"content_id":"content.online-withdrawal-seven-days-vs-defect-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"online-withdrawal-seven-days-vs-defect-deadline","title_ko":"온라인 반품은 7일인가요, 3개월인가요?","one_line_answer_ko":"단순 청약철회는 통상 7일이고 표시·광고나 계약과 다른 상품은 공급일부터 3개월 이내이면서 그 사실을 안 날부터 30일 이내를 함께 확인합니다.","audience_situation_ko":"온라인 구매품을 반품하려는데 판매자가 7일이 지났다고 거절하는 경우","key_points_ko":["단순 변심과 계약불일치는 기간이 다릅니다.","3개월과 30일 중 편한 하나만 고르는 구조가 아닙니다.","철회 의사표시와 발송 증거를 남깁니다."],"action_steps_ko":["계약서면 수령일과 상품 공급일을 기록합니다.","광고화면과 실제 상품 차이를 촬영합니다.","기간 안에 철회 의사를 추적 가능한 방식으로 보냅니다."],"facts_to_check_ko":["계약서면 수령일","공급일","불일치 인지일","사용·훼손 여부"],"caution_ko":"디지털콘텐츠 제공 개시나 가치가 현저히 감소한 경우 등 철회 제한사유와 판매자의 사전조치 여부도 별도로 확인해야 합니다.","search_intents_ko":["온라인 반품 7일","상품 다름 3개월 30일","청약철회 기간"],"body_sections":[{"heading_ko":"단순 철회 7일","paragraphs_ko":["통상적인 온라인 구매는 계약서면을 받은 날 또는 공급이 늦으면 공급받은 날을 기준으로 7일을 계산합니다."]},{"heading_ko":"계약과 다른 상품","paragraphs_ko":["표시·광고나 계약과 다르면 공급일부터 3개월과 인지일부터 30일을 모두 놓치지 않아야 합니다."]}],"rule_ids":["rule.deadline-timing.02"],"scenario_ids":["scenario.deadline-timing.02"],"source_coordinate_ids":["coord.deadline-timing.ecommerce-ko-0017"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.online-purchase-cancellation-seven-days","content.goods-different-from-advertisement-deadline"]},
    {"content_id":"content.unfair-dismissal-vs-wage-claim-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"unfair-dismissal-vs-wage-claim-deadline","title_ko":"해고 구제 3개월과 임금 3년은 어떻게 다른가요?","one_line_answer_ko":"복직·금전보상 등 부당해고 구제는 해고일부터 3개월 안에 노동위원회에 신청하고, 미지급 임금은 각 임금채권의 3년 시효를 별도로 계산합니다.","audience_situation_ko":"갑자기 해고되면서 임금이나 퇴직금도 받지 못한 경우","key_points_ko":["해고 구제와 임금 청구는 별개의 권리입니다.","3개월은 해고일, 3년은 각 임금채권의 발생시점을 봅니다.","한 절차를 진행했다고 다른 기간이 자동 보전된다고 단정하지 않습니다."],"action_steps_ko":["실제 근로 종료일과 해고통지일을 확정합니다.","월별 미지급 임금과 지급일을 표로 만듭니다.","노동위원회 신청과 임금청구를 분리해 진행합니다."],"facts_to_check_ko":["해고일","임금별 지급일","상시근로자 수","해고통지 내용"],"caution_ko":"부당해고 구제신청 가능 여부에는 사업장 규모 등 별도 요건이 있으므로 3개월 안이라는 사실만으로 신청이 모두 인용되는 것은 아닙니다.","search_intents_ko":["부당해고 3개월","임금체불 3년","해고 임금 청구기한"],"body_sections":[{"heading_ko":"권리가 다릅니다","paragraphs_ko":["해고 구제는 근로관계 회복이나 금전보상 등을, 임금 청구는 이미 발생한 임금 지급을 목표로 합니다."]},{"heading_ko":"기산점이 다릅니다","paragraphs_ko":["해고 구제는 해고 등이 있었던 날을, 임금채권은 각 지급의무가 발생한 시점을 기준으로 관리합니다."]}],"rule_ids":["rule.deadline-timing.03"],"scenario_ids":["scenario.deadline-timing.03"],"source_coordinate_ids":["coord.deadline-timing.labor-standards-ko-0028","coord.deadline-timing.labor-standards-ko-0049"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.unfair-dismissal-remedy-three-months","content.final-wages-after-retirement-14-days"]},
    {"content_id":"content.property-division-vs-consolation-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"property-division-vs-consolation-deadline","title_ko":"이혼 재산분할과 위자료 청구기한은 같은가요?","one_line_answer_ko":"재산분할은 이혼일부터 2년이고, 불법행위에 기초한 위자료는 손해와 가해자를 안 날부터 3년 및 불법행위일부터 10년을 따로 확인합니다.","audience_situation_ko":"이혼 후 재산정리와 배우자의 유책행위에 대한 위자료를 함께 검토하는 경우","key_points_ko":["재산분할과 위자료는 목적과 법적 근거가 다릅니다.","이혼일과 불법행위 관련 날짜를 분리합니다.","재산 은닉 증거와 유책행위 증거도 따로 보존합니다."],"action_steps_ko":["이혼 신고일 또는 판결 확정일을 확인합니다.","혼인 중 재산목록과 기여자료를 정리합니다.","손해·가해자 인지일과 유책행위일을 시간순으로 적습니다."],"facts_to_check_ko":["이혼 성립일","재산 형성 경위","불법행위일","손해·가해자 인지일"],"caution_ko":"위자료 청구의 법적 근거와 구체적 기산점은 사실관계에 따라 달라질 수 있으므로 모든 이혼 위자료를 한 날짜로 계산하면 안 됩니다.","search_intents_ko":["이혼 재산분할 2년","이혼 위자료 3년","재산분할 위자료 기한 차이"],"body_sections":[{"heading_ko":"재산 청산과 손해배상","paragraphs_ko":["재산분할은 혼인 중 협력으로 형성한 재산을 청산하고, 위자료는 위법행위로 인한 정신적 손해를 배상하는 제도입니다."]},{"heading_ko":"날짜를 따로 관리합니다","paragraphs_ko":["재산분할은 이혼 성립일, 불법행위 위자료는 행위일과 손해·가해자 인지일을 중심으로 기간을 검토합니다."]}],"rule_ids":["rule.deadline-timing.04"],"scenario_ids":["scenario.deadline-timing.04"],"source_coordinate_ids":["coord.deadline-timing.civil-act-ko-0839-02","coord.deadline-timing.civil-act-ko-0766"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.divorce-property-division-two-year-period","content.divorce-consolation-money-vs-property-division"]},
    {"content_id":"content.inheritance-choice-vs-recovery-claim-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"inheritance-choice-vs-recovery-claim-deadline","title_ko":"상속포기 3개월과 상속회복 3년은 같은 기간인가요?","one_line_answer_ko":"상속 승인·한정승인·포기는 상속개시를 안 날부터 3개월이고, 참칭상속권자에 대한 상속회복은 침해를 안 날부터 3년 및 침해행위일부터 10년입니다.","audience_situation_ko":"상속채무 때문에 포기를 고민하거나 다른 사람이 상속재산을 상속인처럼 차지한 경우","key_points_ko":["상속 선택과 상속권 침해 회복은 전혀 다른 절차입니다.","사망을 안 날과 침해를 안 날을 구분합니다.","상속재산을 처분하기 전 승인 간주 위험도 확인합니다."],"action_steps_ko":["피상속인 사망과 상속개시 인지일을 적습니다.","재산·채무를 조회하고 보존행위 외 처분을 피합니다.","침해자와 침해행위·인지일 자료를 별도로 모읍니다."],"facts_to_check_ko":["상속개시 인지일","상속재산 처분 여부","상속권 침해자","침해 인지일과 행위일"],"caution_ko":"단순한 공동상속인 사이 분할 다툼이 언제나 민법 제999조의 상속회복청구에 해당하는 것은 아니므로 청구 성격을 먼저 확정해야 합니다.","search_intents_ko":["상속포기 3개월","상속회복청구 3년 10년","상속 기한 차이"],"body_sections":[{"heading_ko":"상속채무 선택","paragraphs_ko":["승인·한정승인·포기의 3개월은 상속을 받을 방식과 채무 책임을 정하는 숙려기간입니다."]},{"heading_ko":"상속권 침해 회복","paragraphs_ko":["상속회복은 참칭상속권자의 침해를 전제로 하며 침해 인지일부터 3년과 행위일부터 10년을 봅니다."]}],"rule_ids":["rule.deadline-timing.05"],"scenario_ids":["scenario.deadline-timing.05"],"source_coordinate_ids":["coord.deadline-timing.civil-act-ko-1019","coord.deadline-timing.civil-act-ko-0999"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.three-month-inheritance-decision-period","content.inheritance-renunciation-procedure","content.limited-acceptance-effect"]},
    {"content_id":"content.payment-order-objection-vs-civil-appeal-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"payment-order-objection-vs-civil-appeal-deadline","title_ko":"지급명령 이의와 민사 항소는 왜 둘 다 2주인가요?","one_line_answer_ko":"둘 다 송달일부터 2주인 불변기간이지만 지급명령 이의는 명령을 소송으로 넘기고, 항소는 제1심 판결을 상급심에서 다투는 절차입니다.","audience_situation_ko":"법원 서류를 받고 이의신청인지 항소인지 혼동하는 경우","key_points_ko":["문서 제목과 사건번호를 먼저 확인합니다.","두 절차 모두 송달일 관리가 핵심입니다.","제출서류와 그 뒤 진행절차는 다릅니다."],"action_steps_ko":["전자송달 또는 우편송달 완료일을 확인합니다.","지급명령인지 판결서인지 구분합니다.","해당 법원에 맞는 이의신청서 또는 항소장을 제출합니다."],"facts_to_check_ko":["송달 문서 종류","송달일","사건번호","다툴 범위"],"caution_ko":"내용을 검토하느라 2주가 지난 뒤 서류를 내면 불변기간 문제가 생길 수 있으므로 이유 정리와 불복장 제출을 병행해야 합니다.","search_intents_ko":["지급명령 이의 2주","민사 항소 2주","법원 서류 불복기간"],"body_sections":[{"heading_ko":"지급명령 이의","paragraphs_ko":["채무자가 적법하게 이의하면 지급명령은 해당 범위에서 효력을 잃고 청구는 소송절차로 이어집니다."]},{"heading_ko":"민사 항소","paragraphs_ko":["제1심 판결서가 송달된 경우에는 2주 안에 항소장을 제출해 상급심 판단을 구합니다."]}],"rule_ids":["rule.deadline-timing.06"],"scenario_ids":["scenario.deadline-timing.06"],"source_coordinate_ids":["coord.deadline-timing.civil-procedure-ko-0470","coord.deadline-timing.civil-procedure-ko-0396"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.payment-order-objection-two-weeks","content.when-payment-order-fits"]},
    {"content_id":"content.summary-order-formal-trial-vs-criminal-appeal-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"summary-order-formal-trial-vs-criminal-appeal-deadline","title_ko":"약식명령 정식재판과 형사항소는 둘 다 7일인가요?","one_line_answer_ko":"둘 다 7일이지만 약식명령에는 정식재판을 청구하고, 공판을 거친 제1심 형사판결에는 항소를 제기합니다.","audience_situation_ko":"벌금 관련 법원 문서를 받고 어떤 불복서류를 내야 하는지 모르는 경우","key_points_ko":["검찰의 구약식 통지와 법원의 약식명령을 구분합니다.","약식명령과 공판판결의 불복방법이 다릅니다.","고지·선고 시점과 제출법원을 즉시 확인합니다."],"action_steps_ko":["문서 발행기관과 제목을 확인합니다.","법원 고지 또는 판결 선고 시점을 기록합니다.","정식재판청구서 또는 항소장을 해당 법원에 제출합니다."],"facts_to_check_ko":["재판 형식","고지·선고 시점","문서 발행기관","불복 이유"],"caution_ko":"검찰의 처분 통지일만 보고 7일을 계산하거나 정식재판청구와 항소를 같은 서류로 생각하면 안 됩니다.","search_intents_ko":["약식명령 7일","정식재판 항소 차이","벌금 판결 불복"],"body_sections":[{"heading_ko":"약식명령을 받았다면","paragraphs_ko":["약식명령을 고지받은 피고인 등은 약식명령을 한 법원에 정식재판을 청구합니다."]},{"heading_ko":"공판판결을 받았다면","paragraphs_ko":["제1심 공판판결에 불복하는 경우에는 형사 항소절차를 선택합니다."]}],"rule_ids":["rule.deadline-timing.07"],"scenario_ids":["scenario.deadline-timing.07"],"source_coordinate_ids":["coord.deadline-timing.criminal-procedure-ko-0453","coord.deadline-timing.criminal-procedure-ko-0358"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.summary-order-vs-formal-trial"]},
    {"content_id":"content.industrial-accident-review-vs-rereview-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"industrial-accident-review-vs-rereview-deadline","title_ko":"산재 심사청구와 재심사청구는 모두 90일인가요?","one_line_answer_ko":"첫 심사는 보험급여 원결정을 안 날부터 90일, 재심사는 심사 결정을 안 날부터 다시 90일이므로 불복 대상과 통지일을 단계별로 구분합니다.","audience_situation_ko":"산재 불승인이나 급여 결정에 불복하거나 첫 심사에서도 받아들여지지 않은 경우","key_points_ko":["첫 심사와 재심사는 대상 결정이 다릅니다.","각 결정의 인지일부터 90일을 따로 계산합니다.","일부 사건은 판정위원회 심의 여부에 따라 바로 재심사를 검토할 수 있습니다."],"action_steps_ko":["보험급여 원결정 통지서를 보존합니다.","심사 결정 통지일을 별도 기록합니다.","결정별 불복이유와 의학·업무자료를 보완합니다."],"facts_to_check_ko":["원결정 인지일","심사 결정 인지일","판정위원회 심의 여부","결정 종류"],"caution_ko":"산재보험급여 결정에는 일반 행정심판을 제기할 수 없다고 정한 범위가 있으므로 일반 행정심판 기간과 혼동하지 않아야 합니다.","search_intents_ko":["산재 심사청구 90일","산재 재심사청구","산재 불승인 불복기간"],"body_sections":[{"heading_ko":"첫 불복","paragraphs_ko":["보험급여 결정 등에 대한 심사 청구는 해당 결정을 안 날부터 90일 안에 공단 소속 기관을 거쳐 제기합니다."]},{"heading_ko":"두 번째 불복","paragraphs_ko":["심사 결정에 불복하면 그 결정을 안 날부터 90일 안에 재심사위원회 재심사를 청구합니다."]}],"rule_ids":["rule.deadline-timing.08"],"scenario_ids":["scenario.deadline-timing.08"],"source_coordinate_ids":["coord.deadline-timing.industrial-accident-ko-0103","coord.deadline-timing.industrial-accident-ko-0106"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.industrial-accident-benefits-vs-civil-damages"]},
    {"content_id":"content.labor-commission-rereview-vs-lawsuit-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"labor-commission-rereview-vs-lawsuit-deadline","title_ko":"노동위원회 재심 10일과 소송 15일은 언제 계산하나요?","one_line_answer_ko":"지방·특별노동위원회 처분은 송달일부터 10일 안에 중앙노동위원회 재심을, 중앙노동위원회 처분은 송달일부터 15일 안에 소송을 제기합니다.","audience_situation_ko":"부당해고 등 노동위원회 판정을 받고 다음 불복단계를 검토하는 경우","key_points_ko":["처분기관이 어느 노동위원회인지 확인합니다.","두 기간 모두 송달일이 핵심입니다.","일반 행정심판 90일을 적용한다고 생각하면 안 됩니다."],"action_steps_ko":["판정서 표지와 송달증명을 보존합니다.","지방·특별·중앙 중 처분기관을 표시합니다.","10일 또는 15일 안에 해당 불복서류를 제출합니다."],"facts_to_check_ko":["처분기관","판정서 송달일","처분 내용","이전 불복단계"],"caution_ko":"개별 노동관계 법령에 특별한 불복 규정이 있을 수 있으므로 노동위원회법 조문만으로 모든 사건을 일률 계산하면 안 됩니다.","search_intents_ko":["노동위원회 재심 10일","중앙노동위원회 소송 15일","부당해고 판정 불복"],"body_sections":[{"heading_ko":"지방 판정 뒤 재심","paragraphs_ko":["지방 또는 특별노동위원회 처분은 원칙적으로 송달일부터 10일 안에 중앙노동위원회 재심을 신청합니다."]},{"heading_ko":"중앙 처분 뒤 소송","paragraphs_ko":["중앙노동위원회 처분은 위원장을 피고로 하여 송달일부터 15일 안에 소송을 제기합니다."]}],"rule_ids":["rule.deadline-timing.09"],"scenario_ids":["scenario.deadline-timing.09"],"source_coordinate_ids":["coord.deadline-timing.labor-commission-ko-0026","coord.deadline-timing.labor-commission-ko-0027"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.unfair-dismissal-remedy-three-months"]},
    {"content_id":"content.compensation-order-vs-crime-victim-relief-deadline","content_type":"similar_case_comparison","editorial_status":"approved","reviewed_at":"2026-07-21T18:30:00+00:00","expires_at":"2026-10-21T18:30:00+00:00","slug":"compensation-order-vs-crime-victim-relief-deadline","title_ko":"범죄피해 배상명령과 구조금은 언제까지 신청하나요?","one_line_answer_ko":"배상명령은 형사사건 제1심 또는 제2심 변론종결 전까지, 구조금은 피해 발생을 안 날부터 3년 및 피해 발생일부터 10년 안에 신청해야 합니다.","audience_situation_ko":"범죄피해를 입고 가해자 배상과 국가 구조금을 함께 알아보는 경우","key_points_ko":["배상명령과 구조금은 대상·요건·기관이 다릅니다.","배상명령은 형사재판 진행단계가 기한입니다.","구조금은 피해 인지일과 발생일의 두 제한을 확인합니다."],"action_steps_ko":["형사사건 번호와 현재 공판단계를 확인합니다.","배상받지 못한 손해와 증빙을 정리합니다.","피해 인지일·발생일과 구조금 요건을 확인합니다."],"facts_to_check_ko":["형사재판 단계","대상범죄와 손해","가해자 배상 여부","피해 인지일과 발생일"],"caution_ko":"모든 범죄와 모든 손해가 배상명령 또는 구조금 대상이 되는 것은 아니며 두 제도는 단순히 더 유리한 하나를 고르는 관계도 아닙니다.","search_intents_ko":["배상명령 신청기한","범죄피해 구조금 3년 10년","범죄피해 배상 신청"],"body_sections":[{"heading_ko":"형사재판 안의 배상명령","paragraphs_ko":["대상범죄의 직접 피해자는 제1심 또는 제2심 공판의 변론이 끝나기 전에 사건이 계속된 법원에 배상신청을 합니다."]},{"heading_ko":"국가 구조금 신청","paragraphs_ko":["구조금 지급요건에 해당하면 관할 지구심의회에 신청하되 피해 인지일부터 3년과 발생일부터 10년을 확인합니다."]}],"rule_ids":["rule.deadline-timing.10"],"scenario_ids":["scenario.deadline-timing.10"],"source_coordinate_ids":["coord.deadline-timing.litigation-promotion-ko-0026","coord.deadline-timing.crime-victim-protection-ko-0025"],"hub_ids":["hub.deadline-and-timing-comparisons"],"related_content_ids":["content.compensation-order-application-deadline","content.compensation-order-eligible-damages","content.crime-victim-relief-fund-eligibility-deadline"]}
  ]
