  "rule_cards": [
    {
      "rule_id": "rule.commercial-lease.scope",
      "title_ko": "보증금 규모와 관계없이 조문별 적용범위를 나누어 확인",
      "proposition_ko": "상가건물 임대차보호법은 사업자등록 대상 건물의 영업용 임대차에 적용되며, 환산보증금이 기준을 넘더라도 대항력·갱신·권리금 등 일부 조문은 적용될 수 있습니다.",
      "norm": {
        "actor_ko": "상가건물을 영업용으로 임차한 사업자 또는 예비 임차인",
        "conditions_ko": "건물 용도, 사업자등록 대상 여부, 지역과 환산보증금을 확인하는 경우",
        "legal_effect_ko": "일률적으로 법 전체의 적용 여부를 단정하지 않고 보호하려는 권리마다 적용 조문을 따로 판단합니다."
      },
      "source_coordinate_ids": [
        "coord.commercial-lease.commercial-lease-ko-0002"
      ]
    },
    {
      "rule_id": "rule.commercial-lease.opposability",
      "title_ko": "건물 인도와 사업자등록 신청 다음 날 대항력 발생",
      "proposition_ko": "등기 없는 상가임대차도 건물을 인도받고 사업자등록을 신청하면 그 다음 날부터 제3자에게 효력이 생깁니다.",
      "norm": {
        "actor_ko": "상가를 인도받아 영업하며 사업자등록을 신청한 임차인",
        "conditions_ko": "건물 인도와 사업자등록 신청을 모두 갖추고 소유자 변경 등 제3자 관계가 문제되는 경우",
        "legal_effect_ko": "요건을 유지한 임차인은 새 소유자 등에게 임대차관계를 주장할 수 있고 건물 양수인은 원칙적으로 임대인 지위를 승계합니다."
      },
      "source_coordinate_ids": [
        "coord.commercial-lease.commercial-lease-ko-0003"
      ]
    },
    {
      "rule_id": "rule.commercial-lease.priority-repayment",
      "title_ko": "대항요건과 확정일자를 갖춘 뒤 우선변제 순위 확보",
      "proposition_ko": "건물 인도·사업자등록 신청과 임대차계약서의 확정일자를 갖춘 임차인은 경매·공매에서 후순위권리자보다 우선하여 보증금을 변제받을 수 있습니다.",
      "norm": {
        "actor_ko": "대항요건과 확정일자를 갖춘 상가임차인",
        "conditions_ko": "임차 상가가 경매 또는 공매되고 보증금 배당순위가 문제되는 경우",
        "legal_effect_ko": "대항력만으로 우선변제권이 생기는 것은 아니며 각 요건을 갖춘 시점을 기준으로 다른 권리와 순위를 비교합니다."
      },
      "source_coordinate_ids": [
        "coord.commercial-lease.commercial-lease-ko-0003",
        "coord.commercial-lease.commercial-lease-ko-0004",
        "coord.commercial-lease.commercial-lease-ko-0005"
      ]
    },
    {
      "rule_id": "rule.commercial-lease.lease-registration-order",
      "title_ko": "계약 종료 뒤 보증금 미반환 시 임차권등기명령 검토",
      "proposition_ko": "임대차가 끝났는데도 보증금을 돌려받지 못한 임차인은 관할 법원에 임차권등기명령을 신청할 수 있습니다.",
      "norm": {
        "actor_ko": "종료한 상가임대차의 보증금을 돌려받지 못한 임차인",
        "conditions_ko": "이전이나 점포 반환이 필요하지만 대항력·우선변제권을 보전해야 하는 경우",
        "legal_effect_ko": "임차권등기가 완료되면 이사하거나 사업자등록지를 옮긴 뒤에도 법정 범위에서 기존 대항력과 우선변제권을 보전할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.commercial-lease.commercial-lease-ko-0006"
      ]
    },
    {
      "rule_id": "rule.commercial-lease.minimum-term",
      "title_ko": "1년 미만 약정은 원칙적으로 1년으로 보되 임차인은 짧은 기간 주장 가능",
      "proposition_ko": "기간을 정하지 않았거나 1년 미만으로 정한 상가임대차는 원칙적으로 1년으로 보지만 임차인은 1년 미만의 약정기간이 유효하다고 주장할 수 있습니다.",
      "norm": {
