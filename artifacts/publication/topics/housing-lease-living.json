  "rule_cards": [
    {
      "rule_id": "rule.housing-lease-living.repair-duty",
      "title_ko": "집이 고장 나면 누가 수리해야 하는가",
      "proposition_ko": "임대인은 계약기간 동안 주택을 임차인이 사용·수익하는 데 필요한 상태로 유지할 의무가 있지만, 고장의 원인·정도와 계약상 분담에 따라 구체적 수선책임은 달라집니다.",
      "norm": {
        "actor_ko": "임대인과 임차인",
        "conditions_ko": "누수·난방·전기·구조 등 사용에 필요한 기능이 훼손되고 임차인 귀책 여부가 문제되는 경우",
        "legal_effect_ko": "임대인에게 수선을 요구할 수 있고, 임차인 귀책이나 사소한 관리사항은 계약과 사실관계에 따라 달리 판단합니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.civil-0623"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.repair-reimbursement",
      "title_ko": "세입자가 먼저 낸 수리비를 돌려받는 요건",
      "proposition_ko": "임차물이 보존되도록 하기 위한 필요비를 임차인이 지출했다면 임대인에게 상환을 청구할 수 있고, 유익비는 임대차 종료 때 가치 증가가 남아 있는 범위에서 청구할 수 있습니다.",
      "norm": {
        "actor_ko": "수리비·개량비를 지출한 임차인과 임대인",
        "conditions_ko": "지출이 보존에 필요한 비용인지 가치 증가를 위한 유익비인지, 원인·동의·증빙이 확인되는 경우",
        "legal_effect_ko": "필요비와 유익비를 구분해 영수증·통지·수리 전후 자료로 상환 범위와 시기를 청구할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.civil-0626"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.sublease",
      "title_ko": "집주인 동의 없는 전대와 임차권 양도",
      "proposition_ko": "임차인은 원칙적으로 임대인 동의 없이 임차권을 양도하거나 주택을 전대할 수 없고, 이를 위반하면 임대인이 계약을 해지할 수 있습니다.",
      "norm": {
        "actor_ko": "주택을 다른 사람에게 넘기거나 함께 사용하게 하려는 임차인과 임대인",
        "conditions_ko": "점유 이전의 실질이 단순 동거인지 임차권 양도·전대인지, 임대인의 동의가 있는지 문제되는 경우",
        "legal_effect_ko": "서면 동의를 확보하고 사용범위·기간·책임을 명확히 하지 않으면 계약해지 위험이 생깁니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.civil-0629"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.rent-arrears",
      "title_ko": "월세가 2기 연체되면 바로 계약이 끝나는가",
      "proposition_ko": "건물 임대차에서 차임 연체액이 2기의 차임액에 이르면 임대인은 계약을 해지할 수 있고, 이런 연체는 묵시갱신과 계약갱신요구 보호에서도 불리하게 작용합니다.",
      "norm": {
        "actor_ko": "월세가 밀린 임차인과 해지를 검토하는 임대인",
        "conditions_ko": "연체액이 월 차임 2기분에 달했는지, 변제·공탁·상계·해지통지가 있었는지 확인되는 경우",
        "legal_effect_ko": "2기분 연체가 자동 종료를 뜻하지는 않지만 임대인의 해지권과 갱신거절 근거가 될 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.civil-0640",
        "coord.housing-lease-living.housing-0006",
        "coord.housing-lease-living.housing-0006-3"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.minimum-term",
      "title_ko": "1년으로 쓴 주택임대차의 법정기간",
      "proposition_ko": "기간을 정하지 않았거나 2년 미만으로 정한 주택임대차는 원칙적으로 2년으로 보지만, 임차인은 자신에게 유리하면 약정한 짧은 기간의 유효를 주장할 수 있습니다.",
      "norm": {
        "actor_ko": "1년 등 2년 미만 주택임대차를 체결한 임대인과 임차인",
        "conditions_ko": "실제 계약기간이 2년 미만이고 임차인이 계속 거주 또는 약정기한 종료 중 어느 쪽을 주장하는지 문제되는 경우",
        "legal_effect_ko": "임대인은 임의로 1년 만료를 강제하기 어렵고, 임차인은 법정 2년 보호 또는 짧은 약정기간을 선택적으로 주장할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.housing-0004"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.renewal-request",
      "title_ko": "계약갱신요구권의 횟수와 행사시기",
      "proposition_ko": "임차인은 임대차 종료 6개월 전부터 2개월 전까지 1회에 한해 계약갱신을 요구할 수 있고, 갱신기간은 2년으로 봅니다.",
      "norm": {
        "actor_ko": "계약 만료를 앞둔 주택 임차인과 임대인",
        "conditions_ko": "법정 행사기간 안에 도달하는 갱신요구가 있고 정당한 거절사유가 없는 경우",
        "legal_effect_ko": "임대인은 원칙적으로 갱신을 받아들여야 하며 임차인은 도달 증거와 행사 횟수를 남겨야 합니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.housing-0006-3"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.actual-residence",
      "title_ko": "집주인의 실거주 갱신거절과 제3자 재임대",
      "proposition_ko": "임대인 또는 그 직계존비속의 실제 거주는 갱신거절 사유가 될 수 있지만, 정당한 사유 없이 갱신됐을 기간이 끝나기 전에 제3자에게 다시 임대하면 손해배상책임이 생길 수 있습니다.",
      "norm": {
        "actor_ko": "실거주를 이유로 퇴거를 요구받은 임차인과 임대인",
        "conditions_ko": "실제 거주 의사·거주 주체·퇴거 후 제3자 임대 시기와 정당한 사유가 문제되는 경우",
        "legal_effect_ko": "실거주 거절의 진정성과 후속 사용을 확인하고 허위·변경 임대가 드러나면 법정 손해배상을 검토할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.housing-0006-3"
      ]
    },
    {
      "rule_id": "rule.housing-lease-living.increase-limit",
      "title_ko": "보증금·월세를 5퍼센트보다 많이 올릴 수 있는가",
      "proposition_ko": "경제사정 변동 등이 있으면 장래에 증감을 청구할 수 있지만, 증액은 계약 또는 직전 증액 뒤 1년 안에는 할 수 없고 원칙적으로 약정액의 20분의 1을 초과할 수 없습니다.",
      "norm": {
        "actor_ko": "보증금·월세 증액 통지를 받은 임차인과 증액을 요구하는 임대인",
        "conditions_ko": "직전 계약·증액 시점, 증액률, 지역 조례, 합의갱신 여부가 확인되는 경우",
        "legal_effect_ko": "법정 시기·상한을 넘는 일방 증액청구를 구분하고 합의 여부와 지급내역을 보존해야 합니다."
      },
      "source_coordinate_ids": [
        "coord.housing-lease-living.housing-0007"
      ]
    },
