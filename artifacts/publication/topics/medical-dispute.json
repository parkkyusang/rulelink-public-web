  "rule_cards": [
    {
      "rule_id": "rule.medical-dispute.record-access",
      "title_ko": "환자는 본인 진료기록의 열람·사본을 요구할 수 있음",
      "proposition_ko": "환자는 본인에 관한 진료기록의 전부 또는 일부를 열람하거나 사본 발급 등으로 확인해 달라고 요구할 수 있습니다.",
      "norm": {
        "actor_ko": "본인의 진료 경과와 의료행위 내용을 확인하려는 환자",
        "conditions_ko": "환자가 본인 기록의 범위와 진료기간을 특정해 의료기관에 요청하는 경우",
        "legal_effect_ko": "의료기관은 정당한 사유가 없으면 요청을 거부해서는 안 되며 추가기재·수정 전후 기록도 확인 대상에 포함됩니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.medical-0021"
      ]
    },
    {
      "rule_id": "rule.medical-dispute.representative-access",
      "title_ko": "가족·대리인의 기록 요청은 동의와 증명서류가 필요",
      "proposition_ko": "환자가 아닌 사람의 진료기록 열람은 원칙적으로 제한되고, 법정 가족·대리인 등이 동의서·친족관계·대리권 등 법정 요건을 갖춘 경우에 허용됩니다.",
      "norm": {
        "actor_ko": "환자의 가족, 법정대리인 또는 환자가 지정한 대리인",
        "conditions_ko": "환자가 직접 요청하기 어렵거나 사망·의식불명 등으로 동의를 받을 수 없는 경우",
        "legal_effect_ko": "요청인의 지위와 환자 상태에 맞는 증명서류를 갖춰야 하며 가족이라는 이유만으로 모든 기록을 바로 받을 수 있는 것은 아닙니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.medical-0021"
      ]
    },
    {
      "rule_id": "rule.medical-dispute.record-integrity",
      "title_ko": "진료기록은 상세히 작성·보존하고 거짓 작성이나 고의 수정 금지",
      "proposition_ko": "의료인은 주요 증상·진단·치료 내용과 의견을 상세히 기록·서명하고, 기록을 거짓으로 작성하거나 고의로 사실과 다르게 추가기재·수정해서는 안 됩니다.",
      "norm": {
        "actor_ko": "환자를 진료한 의료인과 진료기록을 보존하는 의료기관",
        "conditions_ko": "진료 경과·처치·검사·투약 기록의 누락이나 사후 수정 여부가 문제되는 경우",
        "legal_effect_ko": "원본과 추가기재·수정 이력을 함께 확보해 시간순으로 대조할 수 있고 의료기관은 법정 방식으로 기록을 보존해야 합니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.medical-0022"
      ]
    },
    {
      "rule_id": "rule.medical-dispute.explanation-consent",
      "title_ko": "중대한 수술·수혈·전신마취는 설명 후 서면동의가 원칙",
      "proposition_ko": "생명·신체에 중대한 위해 우려가 있는 수술·수혈·전신마취는 진단명, 필요성·방법, 참여 의사, 전형적 후유증·부작용, 준수사항을 설명하고 서면동의를 받아야 합니다.",
      "norm": {
        "actor_ko": "수술·수혈·전신마취를 받을 환자와 이를 시행하는 의사·치과의사·한의사",
        "conditions_ko": "응급 예외가 아닌 상태에서 중대한 의료행위를 시행하려는 경우",
        "legal_effect_ko": "환자는 동의서 사본을 요구할 수 있고 주요 시술방법이나 주된 의사가 바뀌면 변경 사유와 내용을 서면으로 고지받아야 합니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.medical-0024-02"
      ]
    },
    {
      "rule_id": "rule.medical-dispute.mediation-application",
      "title_ko": "의료분쟁 당사자는 조정중재원에 조정을 신청 가능",
      "proposition_ko": "의료분쟁 당사자나 대리인은 한국의료분쟁조정중재원에 조정을 신청할 수 있으며 원인행위 종료일부터 10년, 손해와 가해자를 안 날부터 3년 안에 신청해야 합니다.",
      "norm": {
        "actor_ko": "의료사고 피해를 주장하는 환자·가족 또는 의료기관",
        "conditions_ko": "같은 분쟁에 이미 소송이나 다른 법정 조정이 계속 중이지 않고 신청기간 안인 경우",
        "legal_effect_ko": "접수되면 상대방에게 신청서가 송달되고 일반사건은 상대방의 참여 의사, 중대사건은 자동개시 요건에 따라 절차 개시 여부가 정해집니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.dispute-0027"
      ]
    },
    {
      "rule_id": "rule.medical-dispute.ordinary-commencement",
      "title_ko": "일반 사건은 상대방이 14일 안에 참여 의사를 밝혀야 개시",
      "proposition_ko": "일반 의료분쟁 조정은 피신청인이 신청서를 받은 날부터 14일 안에 조정에 응하겠다는 의사를 통지해야 절차가 개시됩니다.",
      "norm": {
        "actor_ko": "일반 의료분쟁의 신청인과 피신청 의료기관",
        "conditions_ko": "사망·1개월 이상 의식불명·법정 중증장애에 해당하지 않는 사건인 경우",
        "legal_effect_ko": "피신청인이 14일 안에 참여 의사를 밝히지 않으면 원장은 조정신청을 각하합니다."
      },
      "source_coordinate_ids": [
        "coord.medical-dispute.dispute-0027"
      ]
    },
