  "rule_cards": [
    {
      "rule_id": "rule.personal-insolvency.rehabilitation-vs-bankruptcy",
      "title_ko": "개인회생과 개인파산, 무엇이 다를까요?",
      "proposition_ko": "개인회생은 정기적 수입과 법정 채무한도 안에서 변제계획을 수행하는 절차이고, 개인파산 면책은 파산절차 뒤 남은 채무책임의 면제를 구하는 별도 판단입니다.",
      "norm": {
        "actor_ko": "지급불능 또는 그 우려가 있는 개인채무자",
        "conditions_ko": "장래 수입의 계속성·채무 규모·보유재산·면책 제한 사유를 비교하는 경우",
        "legal_effect_ko": "정기적 수입으로 변제할 수 있으면 개인회생을, 그 구조가 성립하기 어렵다면 개인파산·면책 가능성을 구분해 검토합니다."
      },
      "source_coordinate_ids": [
        "coord.personal-insolvency.debtor-rehabilitation-ko-0579",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0580",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0564",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0566"
      ]
    },
    {
      "rule_id": "rule.personal-insolvency.personal-rehabilitation-eligibility",
      "title_ko": "개인회생 신청 자격은 소득과 빚을 어떻게 보나요?",
      "proposition_ko": "개인회생채무자는 파산원인이 있거나 생길 염려가 있고 정기적 수입 가능성이 있으며 담보부 15억원, 그 밖의 채무 10억원 이하인 개인채무자입니다.",
      "norm": {
        "actor_ko": "개인회생을 신청하려는 개인채무자",
        "conditions_ko": "파산원인 또는 그 우려, 급여·영업소득의 계속성, 담보부·무담보 채무한도를 모두 확인하는 경우",
        "legal_effect_ko": "법정 자격과 채무한도 안에 있어야 개인회생절차 신청을 검토할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.personal-insolvency.debtor-rehabilitation-ko-0579",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0588"
      ]
    },
    {
      "rule_id": "rule.personal-insolvency.application-documents-creditor-list",
      "title_ko": "개인회생 신청 때 어떤 서류와 채권자목록이 필요한가요?",
      "proposition_ko": "개인회생 신청인은 법원이 판단할 수 있도록 채권자·재산·수입과 지출·소득 형태·진술·최근 도산절차 이력을 갖춘 서류를 제출해야 합니다.",
      "norm": {
        "actor_ko": "개인회생을 신청하는 채무자",
        "conditions_ko": "신청서와 법정 첨부서류를 작성하고 모든 개인회생채권을 채권자목록과 대조하는 경우",
        "legal_effect_ko": "누락·허위·기한 미준수로 인한 신청 기각과 면책 제외 위험을 줄일 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.personal-insolvency.debtor-rehabilitation-ko-0581",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0589",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0595",
        "coord.personal-insolvency.debtor-rehabilitation-ko-0625"
      ]
    },
    {
      "rule_id": "rule.personal-insolvency.filing-does-not-automatically-stop-collection",
      "title_ko": "개인회생을 신청하면 추심과 압류가 바로 자동 중단될까요?",
      "proposition_ko": "개인회생 신청 전후의 집행 통제는 신청 자체, 개시 전 법원 명령, 개시결정의 법정 효과를 구분해야 합니다.",
      "norm": {
