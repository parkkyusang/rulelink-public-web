  "rule_cards": [
    {
      "rule_id": "rule.civil-small-claims.jurisdiction",
      "title_ko": "어느 법원에 민사소송을 내는가",
      "proposition_ko": "민사소송은 원칙적으로 피고의 보통재판적이 있는 법원에 내지만, 재산권 청구는 의무이행지 법원에도 제기할 수 있습니다.",
      "norm": {
        "actor_ko": "돈이나 물건을 청구하려는 원고와 그 상대방",
        "conditions_ko": "피고의 주소지와 약속한 의무이행지가 서로 다르거나 관할을 선택해야 하는 경우",
        "legal_effect_ko": "피고의 보통재판적 법원과 의무이행지 법원 가운데 사건에 적용되는 관할을 확인해 소를 제기할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.civil-small-claims.civil-0002",
        "coord.civil-small-claims.civil-0008"
      ]
    },
    {
      "rule_id": "rule.civil-small-claims.small-claim-scope",
      "title_ko": "3천만원 이하라고 모두 소액사건인가",
      "proposition_ko": "제소 당시 소송목적의 값이 3천만원 이하인 금전·대체물·유가증권 지급청구의 제1심 사건이 소액사건이며, 일부만 떼어 소액사건으로 만드는 것은 제한됩니다.",
      "norm": {
        "actor_ko": "금전이나 대체물의 지급을 청구하려는 사람",
        "conditions_ko": "제1심 청구가 금전 등의 지급이고 소송목적의 값이 3천만원 이하인지, 청구를 인위적으로 분할한 것은 아닌지 확인되는 경우",
        "legal_effect_ko": "요건을 충족하면 소액사건 특례절차가 적용되지만, 적용을 받기 위한 일부청구는 각하될 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.civil-small-claims.rule-0001-2",
        "coord.civil-small-claims.small-0005-2"
      ]
    },
    {
      "rule_id": "rule.civil-small-claims.filing-method",
      "title_ko": "일반소송과 소액사건의 제기 방식",
      "proposition_ko": "일반 민사소송은 법원에 소장을 제출해 제기하고, 소액사건은 법원사무관 등 앞에서 구술로도 제기할 수 있습니다.",
      "norm": {
        "actor_ko": "민사청구를 시작하려는 원고",
        "conditions_ko": "일반 민사소송인지 소액사건인지와 서면 작성 가능 여부를 확인한 경우",
        "legal_effect_ko": "일반소송은 소장을 제출하고, 소액사건은 서면 소장 또는 법정 구술제소 절차를 선택할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.civil-small-claims.civil-0248",
        "coord.civil-small-claims.small-0004"
      ]
    },
    {
      "rule_id": "rule.civil-small-claims.complaint-content",
      "title_ko": "소장에 반드시 적어야 하는 내용",
      "proposition_ko": "소장에는 당사자와 법정대리인, 법원에 구하는 결론인 청구취지, 그 결론을 뒷받침하는 청구원인을 적어야 합니다.",
      "norm": {
        "actor_ko": "민사소장을 작성하는 원고",
        "conditions_ko": "상대방의 특정, 원하는 판결 내용, 이를 뒷받침하는 사실관계를 정리할 수 있는 경우",
        "legal_effect_ko": "필수 기재사항이 빠지지 않도록 당사자·청구취지·청구원인을 구분해 소장을 작성해야 합니다."
      },
      "source_coordinate_ids": [
        "coord.civil-small-claims.civil-0249"
      ]
    },
    {
      "rule_id": "rule.civil-small-claims.answer-default",
      "title_ko": "소장을 받고 답변하지 않으면 생기는 일",
      "proposition_ko": "피고가 청구를 다투려면 소장 부본을 송달받은 날부터 30일 이내 답변서를 제출해야 하고, 내지 않으면 법원이 청구원인 사실을 자백한 것으로 보아 변론 없이 판결할 수 있습니다.",
      "norm": {
        "actor_ko": "민사소장을 송달받은 피고",
        "conditions_ko": "원고 청구의 전부 또는 일부를 다투지만 공시송달이 아닌 방법으로 소장 부본을 송달받은 경우",
        "legal_effect_ko": "30일 안에 구체적인 인정·부인과 항변을 담은 답변서를 내야 하며, 무대응은 변론 없는 판결 위험을 키웁니다."
      },
      "source_coordinate_ids": [
        "coord.civil-small-claims.civil-0256",
        "coord.civil-small-claims.civil-0257"
      ]
    },
    {
      "rule_id": "rule.civil-small-claims.evidence-hearing",
      "title_ko": "첫 기일에 무엇을 준비해야 하는가",
      "proposition_ko": "법원은 변론 전체와 증거조사 결과를 논리와 경험법칙에 따라 평가하며, 소액사건은 되도록 한 차례 변론기일로 심리를 마치므로 핵심 주장과 증거를 일찍 모아야 합니다.",
