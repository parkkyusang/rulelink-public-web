  "rule_cards": [
    {
      "rule_id": "rule.family-inheritance.rule-inheritance-order",
      "title_ko": "법정상속인의 순위",
      "proposition_ko": "법정상속인은 직계비속, 직계존속, 형제자매, 4촌 이내 방계혈족 순이며 동순위에서는 최근친이 선순위다.",
      "norm": {
        "actor_ko": "피상속인의 법정상속인이 될 수 있는 친족",
        "conditions_ko": "피상속인의 사망으로 상속이 개시되고 선순위 친족의 존재와 촌수를 확인하는 경우",
        "legal_effect_ko": "법정상속인은 직계비속, 직계존속, 형제자매, 4촌 이내 방계혈족 순이며 동순위에서는 최근친이 선순위다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1000"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-spouse-order",
      "title_ko": "배우자의 상속순위",
      "proposition_ko": "배우자는 직계비속 또는 직계존속과 동순위 공동상속인이 되고 그들이 없으면 단독상속인이 된다.",
      "norm": {
        "actor_ko": "피상속인의 법률상 배우자",
        "conditions_ko": "법률상 배우자가 있고 직계비속·직계존속의 존재 여부를 확인하는 경우",
        "legal_effect_ko": "배우자는 직계비속 또는 직계존속과 동순위 공동상속인이 되고 그들이 없으면 단독상속인이 된다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1003"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-all-children-renounce",
      "title_ko": "자녀 전원 포기 시 배우자 단독상속",
      "proposition_ko": "배우자와 자녀가 공동상속인인 상황에서 자녀 전부가 상속을 포기하면 배우자가 단독상속인이 되고 손자녀가 배우자와 공동상속인이 되지 않는다는 전원합의체 결정이 있다.",
      "norm": {
        "actor_ko": "피상속인의 배우자와 공동상속인이던 자녀 전원",
        "conditions_ko": "법률상 배우자가 존재하고 공동상속인인 자녀가 모두 적법하게 상속을 포기한 경우",
        "legal_effect_ko": "배우자와 자녀가 공동상속인인 상황에서 자녀 전부가 상속을 포기하면 배우자가 단독상속인이 되고 손자녀가 배우자와 공동상속인이 되지 않는다는 전원합의체 결정이 있다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.src-supreme-2020geu42"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-three-months",
      "title_ko": "상속 승인·포기의 3개월 기간",
      "proposition_ko": "상속인은 상속개시 있음을 안 날부터 3개월 안에 단순승인·한정승인·포기를 선택할 수 있고 가정법원이 기간을 연장할 수 있다.",
      "norm": {
        "actor_ko": "상속개시 사실을 안 상속인",
        "conditions_ko": "상속개시 있음을 안 날부터 3개월 안에 승인·한정승인·포기를 선택하는 경우",
        "legal_effect_ko": "상속인은 상속개시 있음을 안 날부터 3개월 안에 단순승인·한정승인·포기를 선택할 수 있고 가정법원이 기간을 연장할 수 있다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1019"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-renunciation",
      "title_ko": "상속포기의 신고와 소급효",
      "proposition_ko": "상속포기는 3개월 기간 내 가정법원에 신고해야 하고 상속개시 때로 소급해 효력이 생긴다.",
      "norm": {
        "actor_ko": "상속을 포기하려는 상속인",
        "conditions_ko": "상속개시 있음을 안 날부터 3개월 안에 가정법원에 상속포기를 신고하는 경우",
        "legal_effect_ko": "상속포기는 3개월 기간 내 가정법원에 신고해야 하고 상속개시 때로 소급해 효력이 생긴다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1041",
        "coord.family-inheritance.civil-act-ko-1042",
        "coord.family-inheritance.civil-act-ko-1043"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-limited-effect",
      "title_ko": "한정승인의 책임 범위",
      "proposition_ko": "한정승인은 상속으로 취득할 재산 한도에서 피상속인의 채무와 유증을 변제하는 조건의 승인이다.",
