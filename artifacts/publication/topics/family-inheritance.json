  "rule_cards": [
    {
      "rule_id": "rule.family-inheritance.rule-inheritance-order",
      "title_ko": "법정상속인은 직계비속, 직계존속, 형제자매, 4촌 이내 방계혈족 순이며 동순…",
      "proposition_ko": "법정상속인은 직계비속, 직계존속, 형제자매, 4촌 이내 방계혈족 순이며 동순위에서는 최근친이 선순위다.",
      "norm": {
        "actor_ko": "피상속인의 혈족",
        "conditions_ko": "상속개시 당시 선순위 혈족의 존재 여부와 동순위 혈족 사이의 촌수",
        "legal_effect_ko": "직계비속, 직계존속, 형제자매, 4촌 이내 방계혈족 순으로 상속인이 정해지고 동순위에서는 최근친이 우선합니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1000"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-spouse-order",
      "title_ko": "배우자는 직계비속 또는 직계존속과 동순위 공동상속인이 되고 그들이 없으면 단…",
      "proposition_ko": "배우자는 직계비속 또는 직계존속과 동순위 공동상속인이 되고 그들이 없으면 단독상속인이 된다.",
      "norm": {
        "actor_ko": "피상속인의 법률상 배우자",
        "conditions_ko": "상속개시 당시 직계비속 또는 직계존속의 존재 여부",
        "legal_effect_ko": "직계비속 또는 직계존속이 있으면 그들과 공동상속하고, 둘 다 없으면 단독상속합니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1003"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-three-months",
      "title_ko": "상속인은 상속개시 있음을 안 날부터 3개월 안에 단순승인·한정승인·포기를 선…",
      "proposition_ko": "상속인은 상속개시 있음을 안 날부터 3개월 안에 단순승인·한정승인·포기를 선택할 수 있고 가정법원이 기간을 연장할 수 있다.",
      "norm": {
        "actor_ko": "상속개시 있음을 안 상속인",
        "conditions_ko": "상속개시 있음을 안 날부터 3개월 이내이며, 기간 연장은 가정법원의 결정이 있는 경우",
        "legal_effect_ko": "기간 안에 단순승인·한정승인·포기를 선택하고 필요한 경우 기간 연장을 청구할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1019"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-renunciation",
      "title_ko": "상속포기는 3개월 기간 내 가정법원에 신고해야 하고 상속개시 때로 소급해 효…",
      "proposition_ko": "상속포기는 3개월 기간 내 가정법원에 신고해야 하고 상속개시 때로 소급해 효력이 생긴다.",
      "norm": {
        "actor_ko": "상속을 포기하려는 상속인",
        "conditions_ko": "법정기간 안에 가정법원에 상속포기를 신고하여 수리된 경우",
        "legal_effect_ko": "상속개시 때부터 상속인이 아니었던 것으로 봅니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1041",
        "coord.family-inheritance.civil-act-ko-1042",
        "coord.family-inheritance.civil-act-ko-1043"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-limited-effect",
      "title_ko": "한정승인은 상속으로 취득할 재산 한도에서 피상속인의 채무와 유증을 변제하는 …",
      "proposition_ko": "한정승인은 상속으로 취득할 재산 한도에서 피상속인의 채무와 유증을 변제하는 조건의 승인이다.",
      "norm": {
        "actor_ko": "한정승인을 하는 상속인",
        "conditions_ko": "상속재산 목록을 붙여 법정기간 안에 가정법원에 한정승인을 신고한 경우",
        "legal_effect_ko": "상속으로 취득한 재산의 한도에서 피상속인의 채무와 유증을 변제합니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1028"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-limited-procedure",
      "title_ko": "한정승인은 재산목록을 붙여 법원에 신고하고 수리 후 공고·최고와 채권자별 변…",
      "proposition_ko": "한정승인은 재산목록을 붙여 법원에 신고하고 수리 후 공고·최고와 채권자별 변제 절차를 따라야 한다.",
      "norm": {
        "actor_ko": "한정승인자",
        "conditions_ko": "한정승인 후 상속채권자와 유증받은 사람에 대한 공고·최고 및 신고기간을 거친 경우",
        "legal_effect_ko": "우선권과 법정 순서에 따라 상속재산으로 채권자와 유증받은 사람에게 변제합니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1030",
        "coord.family-inheritance.civil-act-ko-1031",
        "coord.family-inheritance.civil-act-ko-1032",
        "coord.family-inheritance.civil-act-ko-1033",
        "coord.family-inheritance.civil-act-ko-1034",
        "coord.family-inheritance.civil-act-ko-1035",
        "coord.family-inheritance.civil-act-ko-1036",
        "coord.family-inheritance.civil-act-ko-1037",
        "coord.family-inheritance.civil-act-ko-1038",
        "coord.family-inheritance.civil-act-ko-1039"
      ]
    },
    {
      "rule_id": "rule.family-inheritance.rule-special-limited",
      "title_ko": "중대한 과실 없이 채무초과 사실을 3개월 내 알지 못하고 단순승인한 경우 그…",
      "proposition_ko": "중대한 과실 없이 채무초과 사실을 3개월 내 알지 못하고 단순승인한 경우 그 사실을 안 날부터 3개월 내 특별한정승인이 가능할 수 있다.",
      "norm": {
        "actor_ko": "상속채무가 상속재산을 초과하는 사실을 뒤늦게 안 상속인",
        "conditions_ko": "법정기간 안에 채무초과를 알지 못한 데 중대한 과실이 없고 그 사실을 안 날부터 3개월 이내인 경우",
        "legal_effect_ko": "특별한정승인을 신고하여 상속재산 한도의 책임을 주장할 수 있습니다."
      },
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1019"
      ]
    }
  ],
  "scenario_branches": [
    {
      "scenario_id": "scenario.family-inheritance.sc-spouse-children",
      "question_ko": "사망 당시 법률상 배우자와 자녀가 모두 있나요?",
      "decision_fact_ko": "법률상 배우자 여부와 직계비속의 존재",
      "when_true_ko": "배우자와 자녀가 공동상속인이 됩니다. 사망 선후·대습상속·상속결격·상속포기는 별도로 확인합니다.",
      "when_false_ko": "자녀가 없으면 직계존속의 존재를 확인하고, 직계비속과 직계존속이 모두 없으면 배우자의 단독상속 여부를 검토합니다.",
      "rule_ids": [
        "rule.family-inheritance.rule-inheritance-order",
        "rule.family-inheritance.rule-spouse-order"
      ],
      "source_coordinate_ids": [
        "coord.family-inheritance.civil-act-ko-1000",
        "coord.family-inheritance.civil-act-ko-1003"
      ]
    },
    {
      "scenario_id": "scenario.family-inheritance.sc-debt-uncertain",
      "question_ko": "상속개시 있음을 안 날부터 아직 3개월이 지나지 않았나요?",
